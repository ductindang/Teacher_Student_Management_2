@using BLL.DTOs
@{
    ViewData["Title"] = "Thêm mới lớp học";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Class
@section HeaderStyles {
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-post.css" />
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/ecommerce-create.css" />

    <link rel="stylesheet" href="~/plugins/table/datatable/datatables.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" />

    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-create.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/dark/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/plugins/tomSelect/tom-select.default.min.css" />

    <link href="~/plugins/filepond/filepond.min.css" rel="stylesheet" />
    <link href="~/plugins/filepond/FilePondPluginImagePreview.min.css" rel="stylesheet" />
    <link href="~/plugins/tagify/tagify.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/editors/quill/quill.snow.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/tagify/custom-tagify.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/filepond/custom-filepond.css" rel="stylesheet" />

    <link href="~/css/customs/assets/light/apps/blog-create.css" rel="stylesheet" />
}

<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 1000px;
        margin: 40px auto;
    }

    .form-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .form-title {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
        transition: 0.2s;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-group label {
        font-weight: 500;
        margin-bottom: 6px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        font-weight: 500;
        margin-top: 10px;
    }

        .submit-btn:hover {
            opacity: 0.9;
        }
</style>

<div class="form-wrapper">

    <div class="form-card">

        <!-- HEADER -->
        <div class="form-title">
            <span>Thêm lớp học mới</span>
            <a asp-action="Index" asp-controller="Class" class="btn-back">
                ← Quay lại
            </a>
        </div>

        <!-- FORM -->
        <form asp-action="Create" method="post">

            <!-- ROW 1 -->
            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Tên lớp học *</label>
                        <input asp-for="Name"
                               class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Nhập tên lớp...">
                        <span asp-validation-for="Name" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Khóa học *</label>
                        <select asp-for="CourseId"
                                class="form-control @(ViewData.ModelState["CourseId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                            <option value="">-- Chọn khóa học --</option>
                            @foreach (var item in ViewBag.Courses)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                        <span asp-validation-for="CourseId" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <!-- ROW 2 -->
            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Giáo viên *</label>
                        <select asp-for="TeacherId"
                                class="form-control @(ViewData.ModelState["TeacherId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                            <option value="">-- Chọn giáo viên --</option>
                            @foreach (var item in ViewBag.Teachers)
                            {
                                <option value="@item.Id">@item.FullName</option>
                            }
                        </select>
                        <span asp-validation-for="TeacherId" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Số học viên tối đa *</label>
                        <input asp-for="MaxStudents"
                               type="number"
                               min="1"
                               class="form-control @(ViewData.ModelState["MaxStudents"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="VD: 30">
                        <span asp-validation-for="MaxStudents" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <!-- ROW 3 -->
            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Ngày bắt đầu *</label>
                        <input asp-for="StartDate"
                               type="date"
                               class="form-control @(ViewData.ModelState["StartDate"]?.Errors.Count > 0 ? "is-invalid" : "")">
                        <span asp-validation-for="StartDate" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Ngày kết thúc *</label>
                        <input asp-for="EndDate"
                               type="date"
                               class="form-control @(ViewData.ModelState["EndDate"]?.Errors.Count > 0 ? "is-invalid" : "")">
                        <span asp-validation-for="EndDate" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <!-- DESCRIPTION -->
            <div class="form-group mb-4">
                <label>Mô tả lớp học</label>
                <div id="blog-description"></div>
                <input type="hidden" id="descriptionInput" asp-for="Description">
            </div>

            <!-- SUBMIT -->
            <button type="submit" class="submit-btn">
                Lưu thông tin
            </button>

        </form>

    </div>

</div>

@section FooterFiles {
    @* <script src="~/js/customs/assets/apps/blog-create.js"></script> *@

    <script src="~/plugins/table/datatable/datatables.js"></script>
    <script src="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.js"></script>
    <script src="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.js"></script>

    <script src="~/plugins/editors/quill/quill.js"></script>
    <script src="~/plugins/filepond/filepond.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginFileValidateType.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageExifOrientation.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImagePreview.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageCrop.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageResize.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageTransform.min.js"></script>
    <script src="~/plugins/filepond/filepondPluginFileValidateSize.min.js"></script>


    <script src="~/plugins/tagify/tagify.min.js"></script>
    <script src="~/js/customs/assets/apps/blog-create.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            $('#create-class-button').on('click', function (e) {
                var html = quill.root.innerHTML;
                document.getElementById("descriptionInput").value = html;
            });
        });
    </script>

    @* <script src="~/plugins/tomSelect/tom-select.base.js"></script>
    <script src="~/plugins/tomSelect/custom-tom-select.js"></script> *@
    @* <script src="~/js/profile/create.js"></script> *@
}