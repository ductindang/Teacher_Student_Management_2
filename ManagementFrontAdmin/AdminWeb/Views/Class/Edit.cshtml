@using BLL.DTOs
@using AdminWeb.Helper.Extensions
@using BLL.DTOs.Enum
@using BLL.Response

@{
    ViewData["Title"] = "Chỉnh sửa lớp học";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@section Styles {
    <link href="~/plugins/table/datatable/datatables.css" rel="stylesheet" />
    <link href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" rel="stylesheet" />
    <link href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" rel="stylesheet" />

    <link href="~/plugins/filepond/filepond.min.css" rel="stylesheet" />
    <link href="~/plugins/filepond/FilePondPluginImagePreview.min.css" rel="stylesheet" />
    <link href="~/plugins/tagify/tagify.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/editors/quill/quill.snow.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/tagify/custom-tagify.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/filepond/custom-filepond.css" rel="stylesheet" />
    
    <link href="~/css/customs/assets/light/apps/blog-create.css" rel="stylesheet" />

}

<style>
    .edit-area {
        padding: 25px;
    }

    #emptyBox{
        width: 200px;
        height: 200px;
        border: 1px dashed #ccc;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
    }
</style>


@model ClassEditViewModel

<div>
    <!-- BREADCRUMB -->
    <div class="page-meta">
        <nav class="breadcrumb-style-one">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Lớp học</a></li>
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Class")">Quản lý lớp học</a>
                </li>
                <li class="breadcrumb-item active">Chỉnh sửa lớp học</li>
            </ol>
        </nav>
    </div>

    <div class="layout-top-spacing col-12">
        <a href="@Url.Action("Index", "Class")" class="btn">Trở lại</a>
    </div>

    <!-- IMAGE -->
    <form asp-action="EditClassImage" method="POST" enctype="multipart/form-data">
        <input type="hidden" asp-for="Class.Id" />

        <div class="row layout-top-spacing">
            <div class="col-md-6">
                <label>Ảnh lớp học</label>

                @if (Model.Class.ClassImage != null)
                {
                    var base64 = Convert.ToBase64String(Model.Class.ClassImage);
                    var imgSrc = $"data:image/jpeg;base64,{base64}";
                    <img id="previewImage" src="@imgSrc" class="img-thumbnail" style="width:100%" />
                }
                else
                {
                    <img id="previewImage" style="display:none;width:100%" />
                    <div id="emptyBox">Chưa có ảnh</div>
                }

                <label class="btn btn-warning mt-2">
                    Thay đổi ảnh
                    <input type="file" id="imageInput" name="file" hidden />
                    <input type="hidden" name="classId" value="@Model.Class.Id" />
                </label>

                <div id="imageActionButtons" style="display:none">
                    <button class="btn btn-success">Lưu ảnh</button>
                    <button type="button" id="cancelImageBtn" class="btn btn-secondary">Huỷ</button>
                </div>
            </div>
        </div>
    </form>

    <!-- FORM -->
    <div class="row layout-top-spacing">
        <div class="col-lg-12">
            <div class="widget box box-shadow">
                <div class="widget-header">
                    <h4>Chỉnh sửa</h4>
                </div>

                <div class="widget-content edit-area">
                    <form asp-action="Edit" method="POST" id="editForm">
                        <input type="hidden" asp-for="Class.Id" />

                        <div class="row">
                            <div class="col-md-6">
                                <label>Tên lớp học *</label>
                                <input asp-for="Class.Name" class="form-control" />
                                <span asp-validation-for="Class.Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label>Khóa học *</label>
                                <select asp-for="Class.CourseId" class="form-control">
                                    <option value="">-- Chọn khóa học --</option>
                                    @foreach (var item in ViewBag.Courses)
                                    {
                                        <option value="@item.Id">@item.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label>Giáo viên *</label>
                                <select asp-for="Class.TeacherId" class="form-control">
                                    <option value="">-- Chọn giáo viên --</option>
                                    @foreach (var item in ViewBag.Teachers)
                                    {
                                        <option value="@item.Id">@item.FullName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label>Số học viên *</label>
                                <input asp-for="Class.MaxStudents" type="number" class="form-control" />
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <label>Ngày bắt đầu *</label>
                                <input asp-for="Class.StartDate" type="date" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label>Ngày kết thúc *</label>
                                <input asp-for="Class.EndDate" type="date" class="form-control" />
                            </div>
                        </div>

                        <!-- QUILL -->
                        <div class="mt-3">
                            <label>Mô tả</label>

                            <div id="blog-description">
                                <div class="quill-editor"></div>
                            </div>

                            <input type="hidden"
                                   id="descriptionInput"
                                   name="Class.Description"
                                   asp-for="Class.Description" />
                        </div>

                        <button id="edit-class-button" class="btn btn-primary mt-3">
                            Hoàn tất
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

</div>


<div>
    <!-- BREADCRUMB -->
    <div class="page-meta">
        <nav class="breadcrumb-style-one" aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Dịch vụ</a></li>
                <li class="breadcrumb-item active" aria-current="page">
                    Quản lý lịch học
                </li>
            </ol>
        </nav>
    </div>
    <!-- /BREADCRUMB -->
    <!-- DATATABLE -->
    <div class="row layout-top-spacing">
        <div class="col-xl-12 col-lg-12 col-sm-12">
            <div class="statbox widget box box-shadow">
                <div class="widget-header">
                    <div class="row">
                        <div class="col-xl-12 col-md-12 col-sm-12 col-12">
                            <h4>Quản lý lịch học</h4>
                        </div>
                    </div>
                </div>
                <div class="widget-content widget-content-area">
                    <div class="layout-top-spacing ps-3 pe-3 col-12 mb-3">
                        <a class="btn btn-primary create" data-classid="@Model.Class.Id">Thêm mới</a>
                    </div>
                    <table id="schedule-table" class="table style-3 dt-table-hover" style="width: 100%">
                        <thead>
                            <tr>
                                <th style="width: 5%">STT</th>
                                <th>Ngày học</th>
                                <th>Thời gian bắt đầu</th>
                                <th>Thời gian kết thúc</th>
                                <th>Phòng học</th>
                                <th class="no-content" style="width: 5%">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int stt = 1;
                            }
                            @if (Model.Schedules != null)
                            {

                                @foreach (var schedule in Model.Schedules)
                                {
                                    <tr>
                                        <td>@stt</td>
                                        <td>@schedule.DayOfWeek.GetDisplayName()</td>
                                        <td>@schedule.StartTime</td>
                                        <td>@schedule.EndTime</td>
                                        <td>@schedule.Room</td>

                                        <td class="table-controls d-flex justify-content-center align-items-center pt-2">
                                            <li>
                                                <a href="#"
                                                   class="bs-tooltip editSchedule"
                                                   data-id="@schedule.Id"
                                                   data-classid="@schedule.ClassId"
                                                   data-day="@((int)schedule.DayOfWeek)"
                                                   data-start="@schedule.StartTime.ToString(@"hh\:mm")"
                                                   data-end="@schedule.EndTime.ToString(@"hh\:mm")"
                                                   data-room="@schedule.Room"
                                                   data-bs-toggle="tooltip"
                                                   data-bs-placement="top">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                         stroke-width="2" stroke-linecap="round"
                                                         stroke-linejoin="round"
                                                         class="feather feather-edit-2 p-1 br-6 mb-1">
                                                        <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z">
                                                        </path>
                                                    </svg>
                                                </a>
                                            </li>
                                            <li>
                                                <a href="#" data-schedule-id="@schedule.Id"
                                                   class="bs-tooltip delete" data-bs-toggle="tooltip"
                                                   data-bs-placement="top">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                         stroke-width="2" stroke-linecap="round"
                                                         stroke-linejoin="round"
                                                         class="feather feather-trash p-1 br-6 mb-1">
                                                        <polyline points="3 6 5 6 21 6"></polyline>
                                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                    </svg>
                                                </a>
                                            </li>
                                        </td>
                                    </tr>

                                    stt++;
                                }
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- /DATATABLE -->
</div>

<div>
    <!-- DATATABLE -->
    <div class="row layout-top-spacing">
        <div class="col-xl-12 col-lg-12 col-sm-12">
            <div class="statbox widget box box-shadow">
                <div class="widget-header">
                    <div class="row">
                        <div class="col-xl-12 col-md-12 col-sm-12 col-12">
                            <h4>Quản lý học viên</h4>
                        </div>
                    </div>
                </div>
                <div class="widget-content widget-content-area">
                    <table id="student-table" class="table style-3 dt-table-hover" style="width: 100%">
                        <thead>
                            <tr>
                                <th style="width: 5%">STT</th>
                                <th>Mã học viên</th>
                                <th>Tên học viên</th>
                                <th>Giới tính</th>
                                <th>Ngày đăng ký</th>
                                <th>Trạng thái đăng ký</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int sttStd = 1;
                            }
                            @if (Model.Students != null)
                            {

                                @foreach (var student in Model.Students)
                                {
                                    <tr>
                                        <td>@sttStd</td>
                                        <td>@student.StudentId</td>
                                        <td>@student.Fullname</td>
                                        <td>@student.Gender.GetDisplayName()</td>
                                        <td>@student.EnrollDate.ToString("dd/MM/yyyy | hh:mm:ss tt")</td>
                                        <td>@student.EnrollStatus.GetDisplayName()</td>
                                    </tr>

                                    sttStd++;
                                }
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- /DATATABLE -->
</div>


@section Scripts {
    <script src="~/plugins/table/datatable/datatables.js"></script>
    <script src="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.js"></script>
    <script src="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.js"></script>

    <script src="~/plugins/editors/quill/quill.js"></script>
    <script src="~/plugins/filepond/filepond.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginFileValidateType.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageExifOrientation.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImagePreview.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageCrop.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageResize.min.js"></script>
    <script src="~/plugins/filepond/FilePondPluginImageTransform.min.js"></script>
    <script src="~/plugins/filepond/filepondPluginFileValidateSize.min.js"></script>


    <script src="~/plugins/tagify/tagify.min.js"></script>
    <script src="~/js/customs/assets/apps/blog-create.js"></script>

    <script>

        // load description khi edit
        var description = `@Html.Raw(Model.Class.Description ?? "")`;

        if (description) {
            quill.root.innerHTML = description;
        }

        // khi submit form
        document.addEventListener("DOMContentLoaded", function () {
            $('#edit-class-button').on('click', function (e) {
                var html = quill.root.innerHTML;
                document.getElementById("descriptionInput").value = html;
            });
        });

    </script>

    <script>
