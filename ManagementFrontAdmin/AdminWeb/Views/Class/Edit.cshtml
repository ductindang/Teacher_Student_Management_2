    <script>
        $('#schedule-table').DataTable(
            {
                "dom": "<'dt--top-section'<'row'<'col-12 col-sm-6 d-flex justify-content-sm-start justify-content-center'l><'col-12 col-sm-6 d-flex justify-content-sm-end justify-content-center mt-sm-0 mt-3'f>>>"
                    + "<'table-responsive'tr>"
                    + "<'dt--bottom-section d-sm-flex justify-content-sm-between text-center'<'dt--pages-count  mb-sm-0 mb-3'i><'dt--pagination'p>>",
                "oLanguage": {
                    "oPaginate": {
                        "sPrevious": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-left"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>',
                        "sNext": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-right"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>'
                    },
                    "sEmptyTable": "Chưa có dữ liệu",
                    "sInfo": "Đang hiển thị trang _PAGE_ của  _PAGES_",
                    "sSearch": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-search"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>',
                    "sSearchPlaceholder": "Tìm kiếm...",
                    "sZeroRecords": "Không có bản ghi nào trùng khớp",
                    "sLengthMenu": "Kết quả :  _MENU_",
                },
                "stripeClasses": [],
                "lengthMenu": [7, 10, 20, 50],
                "pageLength": 10,
                "ordering": false
            });
    </script>

    <script>
        $(document).ready(function () {
            let scheduleIdToDelete;

            $('.delete').on('click', function (e) {
                e.preventDefault();
                scheduleIdToDelete = $(this).data('schedule-id');
                $('#deleteModal').modal('show');
            });


            $('#confirmDelete').on('click', function () {
                $.ajax({
                    url: `/Schedule/Delete`,
                    type: 'POST',
                    data: {
                        id: scheduleIdToDelete
                    },
                    success: function (response) {
                        Snackbar.show({
                            text: 'Xóa lớp học thành công',
                            textColor: '#ddf5f0',
                            backgroundColor: '#00ab55',
                            actionText: 'Bỏ qua',
                            actionTextColor: '#3b3f5c'
                        });

                        setTimeout(function () {
                            location.reload();
                        }, 1000);
                    },
                    error: function (xhr, status, error) {
                        Snackbar.show({
                            text: 'Xóa lớp học thất bại',
                            textColor: '#fbeced',
                            backgroundColor: '#e7515a',
                            actionText: 'Bỏ qua',
                            actionTextColor: '#3b3f5c'
                        });
                    }
                });

                $('#deleteModal').modal('hide');
            });

            $('.create').on('click', function (e) {
                e.preventDefault();

                var classId = $(this).data('classid');
                console.log("class id: " + classId);

                $('#scheduleClassId').val(classId);

                $('#createScheduleModal').modal('show');
            });

        });

        $(document).ready(function () {

            const imageInput = document.getElementById("imageInput");
            const preview = document.getElementById("previewImage");
            const emptyBox = document.getElementById("emptyBox");
            const actionButtons = document.getElementById("imageActionButtons");
            const cancelBtn = document.getElementById("cancelImageBtn");

            if (!imageInput) return;

            const originalImageSrc = preview ? preview.getAttribute("src") : "";

            imageInput.addEventListener("change", function (event) {

                const file = event.target.files[0];
                if (!file) return;

                const reader = new FileReader();

                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.style.display = "block";

                    if (emptyBox) emptyBox.style.display = "none";

                    actionButtons.style.display = "block";
                };

                reader.readAsDataURL(file);
            });

            if (cancelBtn) {
                cancelBtn.addEventListener("click", function () {

                    preview.src = originalImageSrc;

                    if (!originalImageSrc) {
                        preview.style.display = "none";
                        if (emptyBox) emptyBox.style.display = "flex";
                    }
                    console.log("cancel click: " + originalImageSrc);

                    imageInput.value = "";
                    actionButtons.style.display = "none";
                });
            }

        });
    </script>


    <script>
        $(document).on('click', '.editSchedule', function (e) {
            console.log("EDIT CLICKED");
        });
        $(document).on('click', '.editSchedule', function (e) {
            e.preventDefault();

            var scheduleId = $(this).data('id');
            var classId = $(this).data('classid');
            var day = $(this).data('day');
            var start = $(this).data('start') + ":00";
            var end = $(this).data('end') + ":00";
            var room = $(this).data('room');

            console.log("start raw:", "[" + start + "]");
            console.log("length:", start.length);

            $('#scheduleIdEdit').val(scheduleId);
            $('#scheduleClassIdEdit').val(classId);

            $('select[name="DayOfWeek"]').val(day);
            $('#startTimeEdit').val(start);
            $('#endTimeEdit').val(end);
            $('input[name="Room"]').val(room);

            $('#editScheduleModal').modal('show');
        });
    </script>
}