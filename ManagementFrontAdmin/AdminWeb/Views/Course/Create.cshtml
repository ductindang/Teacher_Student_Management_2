@using BLL.DTOs
@using BLL.DTOs.Enum
@{
    ViewData["Title"] = "Thêm mới khóa học";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Course
@section HeaderStyles {
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-post.css" />
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/ecommerce-create.css" />

    <link rel="stylesheet" href="~/plugins/table/datatable/datatables.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" />

    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-create.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/dark/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/plugins/tomSelect/tom-select.default.min.css" />
}
<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 900px;
        margin: 40px auto;
    }

    .form-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .form-title {
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
        transition: 0.2s;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-group label {
        font-weight: 500;
        margin-bottom: 6px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
        transition: 0.2s;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        font-weight: 500;
        margin-top: 10px;
    }

        .submit-btn:hover {
            opacity: 0.9;
        }
</style>

<div class="form-wrapper">

    <div class="form-card">

        <!-- HEADER -->
        <div class="form-title">
            <span>Thêm khóa học mới</span>
            <a asp-action="Index" asp-controller="Course" class="btn-back">
                ← Quay lại
            </a>
        </div>

        <!-- FORM -->
        <form asp-action="Create" method="post">

            <!-- ROW 1 -->
            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Tên khóa học *</label>
                        <input asp-for="Name"
                               class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Nhập tên khóa học...">
                        <span asp-validation-for="Name" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Thời gian (tháng) *</label>
                        <input asp-for="Duration"
                               type="number"
                               min="1"
                               class="form-control @(ViewData.ModelState["Duration"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="VD: 6">
                        <span asp-validation-for="Duration" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <!-- ROW 2 -->
            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Học phí *</label>
                        <input asp-for="Price"
                               type="number"
                               step="0.1"
                               min="0"
                               class="form-control @(ViewData.ModelState["Price"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Nhập học phí...">
                        <span asp-validation-for="Price" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Trạng thái *</label>
                        <select asp-for="Status"
                                class="form-control @(ViewData.ModelState["Status"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                asp-items="Html.GetEnumSelectList<ECourseStatus>()">
                        </select>
                        <span asp-validation-for="Status" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <!-- DESCRIPTION -->
            <div class="form-group mb-4">
                <label>Mô tả khóa học *</label>
                <input asp-for="Description"
                       class="form-control @(ViewData.ModelState["Description"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       placeholder="Nhập mô tả khóa học...">
                <span asp-validation-for="Description" class="invalid-feedback"></span>
            </div>

            <!-- SUBMIT -->
            <button type="submit" class="submit-btn">
                Lưu thông tin
            </button>

        </form>

    </div>

</div>

@section FooterFiles {
    @* <script src="~/js/customs/assets/apps/blog-create.js"></script> *@

    <script src="~/plugins/table/datatable/datatables.js"></script>
    <script src="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.js"></script>
    <script src="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.js"></script>

    @* <script src="~/plugins/tomSelect/tom-select.base.js"></script>
    <script src="~/plugins/tomSelect/custom-tom-select.js"></script> *@
    @* <script src="~/js/profile/create.js"></script> *@
}