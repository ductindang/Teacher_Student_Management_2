@using BLL.DTOs
@using BLL.DTOs.Enum
@{
    ViewData["Title"] = "Chỉnh sửa khóa học";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Course

<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 1100px;
        margin: 30px auto;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 20px;
    }

    .form-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .form-group label {
        font-weight: 500;
        margin-bottom: 6px;
    }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: #fff;
        font-weight: 500;
    }
</style>

<div class="form-wrapper">

    <!-- BREADCRUMB -->
    <div class="mb-3">
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Khóa học</a></li>
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Course")">Quản lý khóa học</a>
                </li>
                <li class="breadcrumb-item active">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>

    <div class="form-card">

        <!-- HEADER -->
        <div class="form-title">
            <span>Chỉnh sửa khóa học</span>
            <a href="@Url.Action("Index", "Course")" class="btn-back">
                ← Quay lại
            </a>
        </div>

        <!-- FORM -->
        <form asp-action="Edit" method="POST">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Tên khóa học *</label>
                        <input asp-for="Name"
                               class="form-control @(ViewData.ModelState["Name"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Tên khóa học">
                        <span asp-validation-for="Name" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Thời gian (tháng) *</label>
                        <input asp-for="Duration"
                               type="number"
                               min="1"
                               class="form-control @(ViewData.ModelState["Duration"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Số tháng">
                        <span asp-validation-for="Duration" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Học phí *</label>
                        <input asp-for="Price"
                               type="number"
                               step="0.1"
                               min="0"
                               class="form-control @(ViewData.ModelState["Price"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Học phí">
                        <span asp-validation-for="Price" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Trạng thái *</label>
                        <select asp-for="Status"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<ECourseStatus>()">
                        </select>
                        <span asp-validation-for="Status" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <div class="form-group mb-4">
                <label>Mô tả *</label>
                <input asp-for="Description"
                       class="form-control @(ViewData.ModelState["Description"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       placeholder="Mô tả khóa học">
                <span asp-validation-for="Description" class="invalid-feedback"></span>
            </div>

            <button type="submit" class="submit-btn">
                Cập nhật
            </button>

        </form>

    </div>
</div>