@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@section Styles {
    <style>

        .dashboard-wrapper {
            padding: 40px 30px;
        }

        /* HERO */
        .dashboard-hero {
            background: linear-gradient(135deg,#4f46e5,#6366f1);
            color: white;
            padding: 40px;
            border-radius: 12px;
            margin-bottom: 30px;
        }

            .dashboard-hero h1 {
                font-size: 32px;
                font-weight: 700;
                margin-bottom: 10px;
            }

            .dashboard-hero p {
                opacity: 0.9;
            }

        /* STATISTICS */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            border-radius: 10px;
            padding: 25px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            transition: 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-4px);
            }

        .stat-title {
            font-size: 14px;
            color: #6b7280;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            margin-top: 5px;
        }

        /* INFO SECTION */
        .dashboard-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .info-card {
            background: white;
            border-radius: 10px;
            padding: 30px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

            .info-card h3 {
                margin-bottom: 15px;
            }

            .info-card img {
                width: 100%;
                border-radius: 8px;
                margin-top: 10px;
            }

    </style>
}

<div class="dashboard-wrapper container-xxl">

    <!-- HERO -->
    <div class="dashboard-hero">
        <h1>Chào mừng đến với hệ thống quản lý học viên</h1>
        <p>
            Quản lý giáo viên, học viên và khóa học một cách nhanh chóng và hiệu quả.
        </p>
    </div>

    <!-- STATISTICS -->
    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-title">Tổng học viên</div>
            <div class="stat-value">120</div>
        </div>

        <div class="stat-card">
            <div class="stat-title">Tổng giáo viên</div>
            <div class="stat-value">18</div>
        </div>

        <div class="stat-card">
            <div class="stat-title">Khóa học</div>
            <div class="stat-value">35</div>
        </div>

    </div>

    <!-- INFO -->
    <div class="dashboard-info">

        <div class="info-card">
            <h3>Quản lý học viên</h3>
            <p>
                Hệ thống cho phép bạn theo dõi thông tin học viên,
                quản lý đăng ký khóa học và theo dõi tiến độ học tập.
            </p>
        </div>

        <div class="info-card">
            <h3>Hệ thống đào tạo</h3>

            <img src="~/images/education-dashboard.jpg" />

        </div>

    </div>

</div>