@using BLL.DTOs
@using BLL.DTOs.Enum
@{
    ViewData["Title"] = "Thêm mới đăng ký";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Enrollment
@section HeaderStyles {
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-post.css" />
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/ecommerce-create.css" />

    <link rel="stylesheet" href="~/plugins/table/datatable/datatables.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" />

    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-create.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/dark/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/plugins/tomSelect/tom-select.default.min.css" />


    <link rel="stylesheet" type="text/css"
          href="/css/customs/plugins/light/tomSelect/custom-tomSelect.css">
    <link rel="stylesheet" type="text/css"
          href="/css/customs/plugins/dark/tomSelect/custom-tomSelect.css">
    <link rel="stylesheet" type="text/css"
          href="/plugins/tomSelect/tom-select.default.min.css">

}
<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 1200px;
        margin: 40px auto;
    }

    .form-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 20px;
    }

    .form-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-group label {
        font-weight: 500;
        margin-bottom: 6px;
    }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: white;
        font-weight: 500;
        margin-top: 10px;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .info-label {
        color: #64748b;
    }

    .info-value {
        font-weight: 500;
        color: #0f172a;
    }
</style>

<div class="form-wrapper">

    <div class="row">

        <!-- LEFT: FORM -->
        <div class="col-lg-8">

            <div class="form-card">

                <div class="form-title">
                    <span>Thêm đăng ký mới</span>
                    <a asp-action="Index" asp-controller="Enrollment" class="btn-back">
                        ← Quay lại
                    </a>
                </div>

                <form asp-action="Create" method="post">

                    <div class="row">

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Học viên *</label>
                                <select asp-for="StudentId" id="studentId"
                                        class="form-control @(ViewData.ModelState["StudentId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                    <option value="">-- Chọn học viên --</option>
                                    @foreach (var item in ViewBag.Students)
                                    {
                                        <option value="@item.Id">@item.FullName</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentId" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Lớp học *</label>
                                <select asp-for="ClassId" id="classId"
                                        class="form-control @(ViewData.ModelState["ClassId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                    <option value="">-- Chọn lớp học --</option>
                                    @foreach (var item in ViewBag.Classes)
                                    {
                                        <option value="@item.Id" data-course-id="@item.CourseId">@item.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="ClassId" class="invalid-feedback"></span>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Ngày đăng ký *</label>
                                <input asp-for="EnrollDate" type="date"
                                       class="form-control @(ViewData.ModelState["EnrollDate"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                <span asp-validation-for="EnrollDate" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Trạng thái *</label>
                                <select asp-for="Status"
                                        class="form-control @(ViewData.ModelState["Status"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                        asp-items="Html.GetEnumSelectList<EEnrollStatus>()">
                                </select>
                                <span asp-validation-for="Status" class="invalid-feedback"></span>
                            </div>
                        </div>

                    </div>

                    <button type="submit" class="submit-btn">
                        Lưu thông tin
                    </button>

                </form>

            </div>

            <!-- STUDENT INFO -->
            <div class="form-card" id="student-info">
                <div class="form-title">Thông tin học viên</div>

                <div class="info-item"><span class="info-label">Mã:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Tên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Ngày sinh:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Giới tính:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Địa chỉ:</span><span class="info-value"></span></div>
            </div>

        </div>

        <!-- RIGHT: CLASS + COURSE -->
        <div class="col-lg-4">

            <div class="form-card" id="class-info">
                <div class="form-title">Thông tin lớp học</div>

                <div class="info-item"><span class="info-label">Mã:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Giáo viên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Tên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Bắt đầu:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Kết thúc:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Sĩ số:</span><span class="info-value"></span></div>
            </div>

            <div class="form-card" id="course-info">
                <div class="form-title">Thông tin khóa học</div>

                <div class="info-item"><span class="info-label">Mã:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Tên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Học phí:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Trạng thái:</span><span class="info-value"></span></div>
            </div>

        </div>

    </div>

</div>

@section FooterFiles {
    <script src="/plugins/tomSelect/tom-select.base.js"></script>
    <script src="/js/course/course.js"></script>
    <script src="/js/class/class.js"></script>
    <script src="/js/student/student.js"></script>

    <script>
        new TomSelect('#studentId', {
            create: true,
            sortField: {
                field: "text",
                direction: "asc"
            }
        });

        new TomSelect('#classId', {
            create: false,
            sortField: {
                field: "text",
                direction: "asc"
            }
        });
        
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function(){
            const studentSelect = document.getElementById("studentId");

            function handleInfo(){

                const studentId = studentSelect.value;

                if(studentId){
                    loadStudentInfo(studentId);
                }
            }

            studentSelect.addEventListener("change", handleInfo);

            if(studentSelect.value){
                handleInfo();
            }
        });
        document.addEventListener("DOMContentLoaded", function(){
            const classSelect = document.getElementById("classId");

            function handleInfo(){
                const selectedOption = classSelect.options[classSelect.selectedIndex];

                const classId = classSelect.value;
                const courseId = selectedOption.getAttribute("data-course-id");

                if(classId){
                    loadClassInfo(classId);
                }

                if(courseId){
                    loadCourseInfo(courseId);
                }
            }

            classSelect.addEventListener("change", handleInfo);

            if(classSelect.value){
                handleInfo();
            }
        });
    </script>
}