@using BLL.DTOs
@using BLL.DTOs.Enum
@{
    ViewData["Title"] = "Chỉnh sửa đăng ký";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Enrollment

<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 1200px;
        margin: 30px auto;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 20px;
    }

    .form-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .form-group label {
        font-weight: 500;
        margin-bottom: 6px;
    }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: #fff;
        font-weight: 500;
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }

    .info-label {
        color: #64748b;
    }

    .info-value {
        font-weight: 500;
        color: #0f172a;
    }
</style>

<div class="form-wrapper">

    <!-- BREADCRUMB -->
    <div class="mb-3">
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Đăng ký</a></li>
                <li class="breadcrumb-item"><a href="@Url.Action("Index", "Enrollment")">Quản lý lớp học</a></li>
                <li class="breadcrumb-item active">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>

    <div class="row">

        <!-- LEFT -->
        <div class="col-lg-8">

            <div class="form-card">

                <div class="form-title">
                    <span>Chỉnh sửa đăng ký</span>
                    <a href="@Url.Action("Index", "Enrollment")" class="btn-back">
                        ← Quay lại
                    </a>
                </div>

                <form asp-action="Edit" method="POST">

                    <div class="row">

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Học viên *</label>
                                <select id="studentId"
                                        asp-for="StudentId"
                                        class="form-control @(ViewData.ModelState["StudentId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                    <option value="">-- Chọn học viên --</option>
                                    @foreach (var item in ViewBag.Students)
                                    {
                                        <option value="@item.Id">@item.FullName</option>
                                    }
                                </select>
                                <span asp-validation-for="StudentId" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Lớp học *</label>
                                <select id="classId"
                                        asp-for="ClassId"
                                        class="form-control @(ViewData.ModelState["ClassId"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                    <option value="">-- Chọn lớp học --</option>
                                    @foreach (var item in ViewBag.Classes)
                                    {
                                        <option value="@item.Id" data-course-id="@item.CourseId">
                                            @item.Name
                                        </option>
                                    }
                                </select>
                                <span asp-validation-for="ClassId" class="invalid-feedback"></span>
                            </div>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Ngày đăng ký *</label>
                                <input asp-for="EnrollDate"
                                       type="date"
                                       class="form-control @(ViewData.ModelState["EnrollDate"]?.Errors.Count > 0 ? "is-invalid" : "")">
                                <span asp-validation-for="EnrollDate" class="invalid-feedback"></span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-4">
                                <label>Trạng thái *</label>
                                <select asp-for="Status"
                                        class="form-control @(ViewData.ModelState["Status"]?.Errors.Count > 0 ? "is-invalid" : "")"
                                        asp-items="Html.GetEnumSelectList<EEnrollStatus>()">
                                </select>
                                <span asp-validation-for="Status" class="invalid-feedback"></span>
                            </div>
                        </div>

                    </div>

                    <button type="submit" class="submit-btn">
                        Cập nhật
                    </button>

                </form>

            </div>

            <!-- STUDENT INFO -->
            <div class="form-card" id="student-info">
                <div class="form-title">Thông tin học viên</div>
                <div class="info-item"><span class="info-label">Mã:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Tên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Ngày sinh:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Giới tính:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Địa chỉ:</span><span class="info-value"></span></div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-4">

            <div class="form-card" id="class-info">
                <div class="form-title">Thông tin lớp học</div>
                <div class="info-item"><span class="info-label">Mã:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Giáo viên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Tên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Bắt đầu:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Kết thúc:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Sĩ số:</span><span class="info-value"></span></div>
            </div>

            <div class="form-card" id="course-info">
                <div class="form-title">Thông tin khóa học</div>
                <div class="info-item"><span class="info-label">Mã:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Tên:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Học phí:</span><span class="info-value"></span></div>
                <div class="info-item"><span class="info-label">Trạng thái:</span><span class="info-value"></span></div>
            </div>

        </div>

    </div>

</div>

@section FooterFiles {
    <script src="/js/course/course.js"></script>
    <script src="/js/class/class.js"></script>
    <script src="/js/student/student.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const studentSelect = document.getElementById("studentId");
            const classSelect = document.getElementById("classId");

            // ===== STUDENT =====
            if (studentSelect) {

                function loadStudent() {
                    const studentId = studentSelect.value;
                    if (studentId) {
                        loadStudentInfo(studentId);
                    }
                }

                studentSelect.addEventListener("change", loadStudent);

                // load khi edit (có sẵn value)
                if (studentSelect.value) {
                    loadStudent();
                }
            }

            // ===== CLASS + COURSE =====
            if (classSelect) {

                function loadClassAndCourse() {
                    const selectedOption = classSelect.options[classSelect.selectedIndex];

                    const classId = classSelect.value;
                    const courseId = selectedOption.getAttribute("data-course-id");

                    if (classId) {
                        loadClassInfo(classId);
                    }

                    if (courseId) {
                        loadCourseInfo(courseId);
                    }
                }

                classSelect.addEventListener("change", loadClassAndCourse);

                // load khi edit (có sẵn value)
                if (classSelect.value) {
                    loadClassAndCourse();
                }
            }

        });
    </script>
}