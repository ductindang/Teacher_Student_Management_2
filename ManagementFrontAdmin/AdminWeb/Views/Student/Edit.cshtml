@using AdminWeb.Helper.Extensions
@using BLL.DTOs
@using BLL.DTOs.Enum
@{
    ViewData["Title"] = "Chỉnh sửa học viên";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Student

@{
    var studentAccount = ViewBag.StudentAccount;
}

<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 1100px;
        margin: 30px auto;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 20px;
    }

    .form-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: #fff;
        font-weight: 500;
    }
</style>

<div class="form-wrapper">

    <!-- BREADCRUMB -->
    <div class="mb-3">
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Người dùng</a></li>
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Student")">Quản lý học viên</a>
                </li>
                <li class="breadcrumb-item active">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>

    <!-- FORM STUDENT -->
    <div class="form-card">

        <div class="form-title">
            <span>Chỉnh sửa học viên</span>
            <a href="@Url.Action("Index", "Student")" class="btn-back">
                ← Quay lại
            </a>
        </div>

        <form asp-action="Edit" method="POST">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-6 mb-4">
                    <label>Tên học viên *</label>
                    <input asp-for="FullName"
                           class="form-control @(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "is-invalid" : "")">
                    <span asp-validation-for="FullName" class="invalid-feedback"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label>Ngày sinh *</label>
                    <input asp-for="DateOfBirth"
                           type="date"
                           class="form-control @(ViewData.ModelState["DateOfBirth"]?.Errors.Count > 0 ? "is-invalid" : "")">
                    <span asp-validation-for="DateOfBirth" class="invalid-feedback"></span>
                </div>

            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label>Giới tính *</label>
                    <select asp-for="Gender"
                            class="form-control"
                            asp-items="Html.GetEnumSelectList<EGender>()">
                    </select>
                </div>

                <div class="col-md-6 mb-4">
                    <label>Địa chỉ *</label>
                    <input asp-for="Address"
                           class="form-control @(ViewData.ModelState["Address"]?.Errors.Count > 0 ? "is-invalid" : "")">
                    <span asp-validation-for="Address" class="invalid-feedback"></span>
                </div>
            </div>

            <button type="submit" class="submit-btn">
                Cập nhật
            </button>

        </form>
    </div>

    <!-- ACCOUNT -->
    @if (studentAccount != null)
    {
        <div class="form-card">

            <div class="form-title">
                <span>Chỉnh sửa tài khoản</span>
            </div>

            <form id="edit-user-form">
                <input type="hidden" name="Id" value="@studentAccount.Id" />

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="Username">Username</label>
                        <input id="Username" name="Username" value="@studentAccount.Username" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label for="PasswordHash">Mật khẩu *</label>
                        <input id="password" name="PasswordHash" class="form-control" oninput="validatePassword()" placeholder="Nhập mật khẩu mới (nếu có)"/>
                        <span id="password-error" class="text-danger mb-5"></span>

                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="email">Email</label>
                        <input id="email" name="Email" value="@studentAccount.Email" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label for="createdAt">Ngày tạo</label>
                        <input id="createdAt" name="CreatedAt" value="@studentAccount.CreatedAt.ToString("dd/MM/yyyy HH:mm")" class="form-control" readonly />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="phone-number">Số điện thoại *</label>
                        <input id="phone-number" value="@studentAccount.Phone" name="Phone" class="form-control" placeholder="Nhập số điện thoại" oninput="validatePhoneNumber()" />
                        <span id="phone-number-error" class="text-danger mb-5"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Trạng thái</label>
                        <select name="Status"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<EAccountStatus>()">
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <input type="hidden" name="RoleId" value="@studentAccount.RoleId"/>
                    <label>Quyền truy cập</label>
                    <input class="form-control"
                           value="@(((ERoleName)studentAccount.RoleId).GetDisplayName())"
                           readonly />
                </div>

                <button type="button" id="btnUpdateAccount" class="submit-btn">
                    Cập nhật tài khoản
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="form-card text-center">
            <p>Người dùng này chưa có tài khoản.</p>
            <button id="btnShowCreateAccount" class="submit-btn">
                Tạo tài khoản
            </button>
        </div>

        <input type="hidden" id="StudentId" value="@Model.Id" />

        <div id="create-account-section" style="display:none" class="form-card">

            <div class="form-title">
                <span>Tạo tài khoản</span>
            </div>

            <form id="create-user-form">

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Username *</label>
                        <input name="Username" class="form-control" placeholder="Nhập username"/>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Mật khẩu *</label>
                        <input id="password" name="PasswordHash" class="form-control" placeholder="Nhập mật khẩu" oninput="validatePassword()" />
                        <span id="password-error" class="text-danger mb-5"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Email *</label>
                        <input id="email" name="Email" placeholder="Nhập email" class="form-control" onblur="checkEmailExist()" />
                        <span id="email-error" class="text-danger mb-5"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Ngày tạo</label>
                        <input value="@DateTime.UtcNow" class="form-control" readonly />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Số điện thoại *</label>
                        <input id="phone-number" name="Phone" class="form-control" placeholder="Nhập số điện thoại" oninput="validatePhoneNumber()" />
                        <span id="phone-number-error" class="text-danger mb-5"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Trạng thái</label>
                        <select name="Status"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<EAccountStatus>()">
                        </select>
                    </div>
                </div>
                <input type="hidden" id="roleId" name="RoleId" value="@((int)ERoleName.Student)" />

                <button type="button" id="btnCreateAccount" class="submit-btn">
                    Tạo tài khoản
                </button>
            </form>
        </div>
    }

</div>

@section Scripts {
    <script src="/js/user/formValidation.js"></script>
    <script src="/js/user/signup.js"></script>
    <script src="/js/student/student.js"></script>


    <script>
        $(document).ready(function () {
            @if (studentAccount != null)
            {
                    <text>
                        $('select[name="Status"]').val('@((int)studentAccount.Status)');
                    </text>
            }
        });

    </script>
}