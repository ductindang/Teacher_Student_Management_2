@using BLL.DTOs
@{
    ViewData["Title"] = "Thêm mới giáo viên";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model Teacher
@section HeaderStyles {
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-post.css" />
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/ecommerce-create.css" />

    <link rel="stylesheet" href="~/plugins/table/datatable/datatables.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" />
    <link rel="stylesheet" href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" />

    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-create.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/dark/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/plugins/tomSelect/tom-select.default.min.css" />

    <style>

        body {
            background: #f1f5f9;
        }

        .form-wrapper {
            max-width: 900px;
            margin: 40px auto;
        }

        .form-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        .form-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-back {
            background: transparent;
            border: 1px solid #cbd5e1;
            padding: 6px 14px;
            border-radius: 6px;
            text-decoration: none;
            color: #334155;
            transition: 0.2s;
        }

            .btn-back:hover {
                background: #f1f5f9;
            }

        .form-group label {
            font-weight: 500;
            margin-bottom: 6px;
        }

        .form-control {
            border-radius: 10px;
            padding: 10px 12px;
            border: 1px solid #e2e8f0;
            transition: 0.2s;
        }

            .form-control:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
            }

        .submit-btn {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            color: white;
            font-weight: 500;
            margin-top: 10px;
        }

            .submit-btn:hover {
                opacity: 0.9;
            }

    </style>
}

<div class="form-wrapper">

    <div class="form-card">

        <!-- HEADER -->
        <div class="form-title">
            <span>Thêm giáo viên mới</span>
            <a asp-action="Index" asp-controller="Teacher" class="btn-back">
                ← Quay lại
            </a>
        </div>

        <!-- FORM -->
        <form asp-action="Create" method="post">

            <div class="row">

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Tên giáo viên *</label>
                        <input asp-for="FullName"
                               class="form-control @(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="Nhập tên...">
                        <span asp-validation-for="FullName" class="invalid-feedback"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group mb-4">
                        <label>Kinh nghiệm (năm) *</label>
                        <input asp-for="Experience"
                               type="number"
                               min="1"
                               class="form-control @(ViewData.ModelState["Experience"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="VD: 3">
                        <span asp-validation-for="Experience" class="invalid-feedback"></span>
                    </div>
                </div>

            </div>

            <div class="form-group mb-4">
                <label>Bằng cấp *</label>
                <input asp-for="Degree"
                       class="form-control @(ViewData.ModelState["Degree"]?.Errors.Count > 0 ? "is-invalid" : "")"
                       placeholder="VD: Thạc sĩ CNTT">
                <span asp-validation-for="Degree" class="invalid-feedback"></span>
            </div>

            <button type="submit" class="submit-btn">
                Lưu thông tin
            </button>

        </form>

    </div>

</div>

@section FooterFiles {
    @* <script src="~/js/customs/assets/apps/blog-create.js"></script> *@

    <script src="~/plugins/table/datatable/datatables.js"></script>
    <script src="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.js"></script>
    <script src="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.js"></script>

    @* <script src="~/plugins/tomSelect/tom-select.base.js"></script>
    <script src="~/plugins/tomSelect/custom-tom-select.js"></script> *@
    @* <script src="~/js/profile/create.js"></script> *@
}