@using AdminWeb.Helper.Extensions
@using BLL.DTOs
@using BLL.DTOs.Enum
@{
    ViewData["Title"] = "Chỉnh sửa giáo viên";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@section Styles {
    <link href="~/plugins/table/datatable/datatables.css" rel="stylesheet" />
    <link href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" rel="stylesheet" />
    <link href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" rel="stylesheet" />
}

@{
    var teacherReviews = ViewBag.TeacherReviews;
    var teacherAccount = ViewBag.TeacherAccount;
}

@model Teacher
<style>
    body {
        background: #f1f5f9;
    }

    .form-wrapper {
        max-width: 1100px;
        margin: 30px auto;
    }

    .form-card {
        background: #fff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        margin-bottom: 20px;
    }

    .form-title {
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-back {
        background: transparent;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 6px;
        text-decoration: none;
        color: #334155;
    }

        .btn-back:hover {
            background: #f1f5f9;
        }

    .form-control {
        border-radius: 10px;
        padding: 10px 12px;
        border: 1px solid #e2e8f0;
    }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 2px rgba(99,102,241,0.1);
        }

    .submit-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        color: #fff;
        font-weight: 500;
    }
</style>
<div class="form-wrapper">

    <!-- BREADCRUMB -->
    <div class="mb-3">
        <nav>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Người dùng</a></li>
                <li class="breadcrumb-item">
                    <a href="@Url.Action("Index", "Teacher")">Quản lý giáo viên</a>
                </li>
                <li class="breadcrumb-item active">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>

    <!-- FORM TEACHER -->
    <div class="form-card">

        <div class="form-title">
            <span>Chỉnh sửa giáo viên</span>
            <a href="@Url.Action("Index", "Teacher")" class="btn-back">
                ← Quay lại
            </a>
        </div>

        <form asp-action="Edit" method="POST">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-6 mb-4">
                    <label>Tên giáo viên *</label>
                    <input asp-for="FullName"
                           class="form-control @(ViewData.ModelState["FullName"]?.Errors.Count > 0 ? "is-invalid" : "")">
                    <span asp-validation-for="FullName" class="invalid-feedback"></span>
                </div>

                <div class="col-md-6 mb-4">
                    <label>Số năm kinh nghiệm *</label>
                    <input asp-for="Experience"
                           type="number"
                           min="1"
                           class="form-control @(ViewData.ModelState["Experience"]?.Errors.Count > 0 ? "is-invalid" : "")">
                    <span asp-validation-for="Experience" class="invalid-feedback"></span>
                </div>

            </div>

            <div class="mb-4">
                <label>Bằng cấp *</label>
                <input asp-for="Degree"
                       class="form-control @(ViewData.ModelState["Degree"]?.Errors.Count > 0 ? "is-invalid" : "")">
                <span asp-validation-for="Degree" class="invalid-feedback"></span>
            </div>

            <button type="submit" class="submit-btn">
                Cập nhật
            </button>

        </form>
    </div>

    <!-- ACCOUNT -->
    @if (teacherAccount != null)
    {
        <div class="form-card">

            <div class="form-title">
                <span>Chỉnh sửa tài khoản</span>
            </div>

            <form id="edit-user-form">
                <input type="hidden" name="Id" value="@teacherAccount.Id" />

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label for="Username">Username</label>
                        <input id="Username" name="Username" value="@teacherAccount.Username" class="form-control" readonly />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Mật khẩu *</label>
                        <input id="password" name="PasswordHash" class="form-control" placeholder="Nhập mật khẩu mới (nếu có)" oninput="validatePassword()" />
                        <span id="password-error" class="text-danger mb-5"></span>

                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Email *</label>
                        <input id="email" name="Email" value="@teacherAccount.Email" class="form-control" onblur="checkEmailExist()" readonly/>
                        <span id="email-error" class="text-danger mb-5"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label for="createdAt">Ngày tạo</label>
                        <input id="createdAt" name="CreatedAt" value="@teacherAccount.CreatedAt.ToString("dd/MM/yyyy HH:mm")" class="form-control" readonly />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Số điện thoại *</label>
                        <input id="phone-number" value="@teacherAccount.Phone" name="Phone" class="form-control" placeholder="Nhập số điện thoại" oninput="validatePhoneNumber()" />
                        <span id="phone-number-error" class="text-danger mb-5"></span>

                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Trạng thái</label>
                        <select name="Status"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<EAccountStatus>()">
                        </select>
                    </div>
                </div>

                <div class="mb-4">
                    <input type="hidden" name="RoleId" value="@teacherAccount.RoleId" />
                    <label>Quyền truy cập</label>
                    <input class="form-control"
                           value="@(((ERoleName)teacherAccount.RoleId).GetDisplayName())"
                           readonly />
                </div>

                <button type="button" id="btnUpdateAccount" class="submit-btn">
                    Cập nhật tài khoản
                </button>
            </form>
        </div>
    }
    else
    {
        <div class="form-card text-center">
            <p>Giáo viên chưa có tài khoản.</p>
            <button id="btnShowCreateAccount" class="submit-btn">
                Tạo tài khoản
            </button>
        </div>

        <input type="hidden" id="TeacherId" value="@Model.Id" />

        <div id="create-account-section" style="display:none" class="form-card">

            <div class="form-title">
                <span>Tạo tài khoản</span>
            </div>

            <form id="create-user-form">

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Username *</label>
                        <input name="Username" class="form-control" placeholder="Nhập username"/>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Mật khẩu *</label>
                        <input id="password" name="PasswordHash" class="form-control" placeholder="Nhập mật khẩu" oninput="validatePassword()" />
                        <span id="password-error" class="text-danger mb-5"></span>

                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Email *</label>
                        <input id="email" name="Email" placeholder="Nhập email" class="form-control" onblur="checkEmailExist()" />
                        <span id="email-error" class="text-danger mb-5"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Ngày tạo</label>
                        <input value="@DateTime.UtcNow" class="form-control" readonly />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label>Số điện thoại *</label>
                        <input id="phone-number" name="Phone" class="form-control" placeholder="Nhập số điện thoại" oninput="validatePhoneNumber()" />
                        <span id="phone-number-error" class="text-danger mb-5"></span>

                    </div>

                    <div class="col-md-6 mb-4">
                        <label>Trạng thái</label>
                        <select name="Status"
                                class="form-control"
                                asp-items="Html.GetEnumSelectList<EAccountStatus>()">
                        </select>
                    </div>
                </div>
                <input type="hidden" id="roleId" name="RoleId" value="@((int)ERoleName.Teacher)" />

                <button type="button" id="btnCreateAccount" class="submit-btn">
                    Tạo tài khoản
                </button>
            </form>
        </div>
    }

</div>

<div>
    <!-- DATATABLE -->
    <div class="row layout-top-spacing">
        <div class="col-xl-12 col-lg-12 col-sm-12">
            <div class="statbox widget box box-shadow">
                <div class="widget-header">
                    <div class="row">
                        <div class="col-xl-12 col-md-12 col-sm-12 col-12">
                            <h4>Quản lý đánh giá giảng viên</h4>
                        </div>
                    </div>
                </div>
                <div class="widget-content widget-content-area">
                    <table id="teacher-table" class="table style-3 dt-table-hover" style="width: 100%">
                        <thead>
                            <tr>
                                <th style="width: 5%">STT</th>
                                <th>Mã đánh giá</th>
                                <th>Tên học viên</th>
                                <th>Số sao</th>
                                <th>Thời gian tạo</th>
                                <th class="no-content" style="width: 5%">Đánh giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int stt = 1;
                            }
                            @if (teacherReviews != null)
                            {

                                @foreach (var review in teacherReviews)
                                {
                                    <tr>
                                        <td>@stt</td>
                                        <td>@review.Id</td>
                                        <td>@review.StudentName</td>
                                        <td>@review.Rating</td>
                                        <td>@review.CreatedAt.ToString("dd/MM/yyyy | hh:mm:ss tt")</td>

                                        <td class="text-center">
                                            <a href="javascript:void(0)"
                                               class="text-primary view-comment"
                                               data-comment="@review.Comment">
                                                Xem chi tiết
                                            </a>
                                        </td>

                                    </tr>

                                    stt++;
                                }
                            }

                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- /DATATABLE -->
</div>

<!-- Scripts riêng cho lớp con -->
@section Scripts {
    <script src="~/plugins/table/datatable/datatables.js"></script>
    <script src="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.js"></script>
    <script src="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.js"></script>
    <script src="/js/user/formValidation.js"></script>
    <script src="/js/user/signup.js"></script>
    <script src="/js/teacher/teacher.js"></script>


    <script>
        $(document).ready(function () {
            @if (teacherAccount != null)
            {
                <text>
                    $('select[name="Status"]').val('@((int)teacherAccount.Status)');
                </text>
            }
        });

    </script>

    <script>
        $('#teacher-table').DataTable(
            {
                "dom": "<'dt--top-section'<'row'<'col-12 col-sm-6 d-flex justify-content-sm-start justify-content-center'l><'col-12 col-sm-6 d-flex justify-content-sm-end justify-content-center mt-sm-0 mt-3'f>>>"
                    + "<'table-responsive'tr>"
                    + "<'dt--bottom-section d-sm-flex justify-content-sm-between text-center'<'dt--pages-count  mb-sm-0 mb-3'i><'dt--pagination'p>>",
                "oLanguage": {
                    "oPaginate": {
                        "sPrevious": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-left"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>',
                        "sNext": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-right"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>'
                    },
                    "sEmptyTable": "Chưa có dữ liệu",
                    "sInfo": "Đang hiển thị trang _PAGE_ của  _PAGES_",
                    "sSearch": '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-search"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>',
                    "sSearchPlaceholder": "Tìm kiếm...",
                    "sZeroRecords": "Không có bản ghi nào trùng khớp",
                    "sLengthMenu": "Kết quả :  _MENU_",
                },
                "stripeClasses": [],
                "lengthMenu": [7, 10, 20, 50],
                "pageLength": 10,
                "ordering": false
            });
    </script>
}