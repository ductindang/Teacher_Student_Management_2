    <script>
                // ===== STATUS BADGE =====
        function getStatusBadge(status) {
            switch (status) {
                case 1:
                    return `<span class="badge-status status-present">✔ Có mặt</span>`;
                case 2:
                    return `<span class="badge-status status-absent">✖ Vắng</span>`;
                case 3:
                    return `<span class="badge-status status-late">⏰ Đi muộn</span>`;
                case 4:
                default:
                    return `<span class="badge-status" style="background:#eee;color:#666">Chưa điểm danh</span>`;
            }
        }

        // ===== DAY TEXT =====
        function getDayOfWeek(day) {
            switch (day) {
                case 0: return "Chủ nhật";
                case 1: return "Thứ 2";
                case 2: return "Thứ 3";
                case 3: return "Thứ 4";
                case 4: return "Thứ 5";
                case 5: return "Thứ 6";
                case 6: return "Thứ 7";
                default: return day;
            }
        }


        // ===== CLICK VIEW ATTENDANCE =====
        $(document).on("click", ".view-attendance", function () {

            var studentId = $(this).data("id");
            var classId = @Model.Id;

            // loading UI
            $("#attendance-body").html(`
                <tr>
                    <td colspan="5" style="text-align:center; padding:20px;">
                        ⏳ Đang tải dữ liệu...
                    </td>
                </tr>
            `);

            $.ajax({
                url: "/Attendance/GetAttendance",
                type: "GET",
                data: { studentId: studentId, classId: classId },

                success: function (data) {

                    if (!data || data.length === 0) {
                        $("#attendance-body").html(`
                            <tr>
                                <td colspan="5" style="text-align:center; padding:20px; color:#888;">
                                    📭 Không có dữ liệu
                                </td>
                            </tr>
                        `);

                        $("#attendanceModal").modal("show");
                        return;
                    }

                    var lessons = [];

                    var startDate = new Date(data[0].startDate);
                    var endDate = new Date(data[0].endDate);
                    var today = new Date();

                    if (today < endDate) {
                        endDate = today;
                    }

                    // ===== BUILD LESSON LIST =====
                    for (var d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {

                        data.forEach(function (schedule) {

                            if (d.getDay() === schedule.dayOfWeek) {

                                var record = data.find(x =>
                                    x.scheduleId === schedule.scheduleId &&
                                    x.attendanceDate &&
                                    new Date(x.attendanceDate).toDateString() === d.toDateString()
                                );

                                var status = record ? record.status : 4;

                                lessons.push({
                                    date: new Date(d),
                                    day: schedule.dayOfWeek,
                                    time: schedule.startTime + " - " + schedule.endTime,
                                    room: schedule.room,
                                    status: status
                                });
                            }

                        });
                    }

                    // sort newest → oldest
                    lessons.sort((a, b) => b.date - a.date);

                    var html = "";

                    lessons.forEach(function (item) {

                        var dateText = item.date.toLocaleDateString("vi-VN");

                        let rowClass = "";
                        if (item.status === 2) rowClass = "row-absent";
                        if (item.status === 3) rowClass = "row-late";

                        html += `
                        <tr class="${rowClass}">
                            <td>${getDayOfWeek(item.day)}</td>
                            <td>${item.time}</td>
                            <td>${dateText}</td>
                            <td>${item.room}</td>
                            <td>${getStatusBadge(item.status)}</td>
                        </tr>
                        `;
                    });

                    $("#attendance-body").html(html);

                    $("#attendanceModal").modal("show");
                },

                error: function () {
                    $("#attendance-body").html(`
                        <tr>
                            <td colspan="5" style="text-align:center; padding:20px; color:red;">
                                ❌ Lỗi tải dữ liệu
                            </td>
                        </tr>
                    `);
                }
            });
        });

        document.addEventListener("DOMContentLoaded", function () {

            const form = document.querySelector('.enroll-form');

            if (form) {

                form.addEventListener('submit', function (e) {

                    e.preventDefault();

                    Swal.fire({
                        title: 'Xác nhận đăng ký?',
                        text: "Bạn có chắc muốn đăng ký lớp học này không?",
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Đăng ký',
                        cancelButtonText: 'Hủy'
                    }).then((result) => {

                        if (result.isConfirmed) {
                            form.submit();
                        }

                    });

                });

            }

        });


        document.querySelectorAll('.confirm-action').forEach(btn => {

            btn.addEventListener('click', function () {

                const url = this.dataset.url;

                Swal.fire({
                    title: 'Bạn có chắc không?',
                    text: 'Hành động này sẽ thay đổi trạng thái đăng ký lớp học.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {

                    if (result.isConfirmed) {
                        window.location.href = url;
                    }

                });

            });

        });

    </script>

    <script>
        const ratingMessages = {
            1: "Rất tệ",
            2: "Không hài lòng",
            3: "Bình thường",
            4: "Tốt",
            5: "Rất tốt"
        };

        document.querySelectorAll('.star-rating .star').forEach(star => {

            star.addEventListener('click', function () {

                let rating = this.getAttribute('data-value');

                document.getElementById('ratingValue').value = rating;

                document.querySelectorAll('.star-rating .star').forEach(s => {
                    s.classList.remove('active');
                });

                for (let i = 0; i < rating; i++) {
                    document.querySelectorAll('.star-rating .star')[i].classList.add('active');
                }

                // hiển thị text
                document.getElementById("ratingText").innerText = ratingMessages[rating];

            });

        });
    </script>

