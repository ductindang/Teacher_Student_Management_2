@using BLL.DTOs
@using BLL.DTOs.Enum
@using BLL.Response
@using ClientWeb.Helper.Extensions
@using Newtonsoft.Json
@model ClassResponse

@{
    ViewData["Title"] = "Lớp học";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@section HeaderStyles {
    <link href="~/plugins/table/datatable/datatables.css" rel="stylesheet" />
    <link href="~/plugins/table/datatable/extensions/col-reorder/col-reorder.datatables.min.css" rel="stylesheet" />
    <link href="~/plugins/table/datatable/extensions/fixed-columns/fixed-columns.datatables.min.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/table/datatable/dt-global_style.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/table/datatable/custom_dt_custom.css" rel="stylesheet" />

    <link href="/css/customs/assets/light/elements/custom-pagination.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" type="text/css" href="/css/customs/assets/light/apps/blog-post.css">


    <link href="~/plugins/filepond/filepond.min.css" rel="stylesheet" />
    <link href="~/plugins/filepond/FilePondPluginImagePreview.min.css" rel="stylesheet" />
    <link href="~/plugins/tagify/tagify.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/editors/quill/quill.snow.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/tagify/custom-tagify.css" rel="stylesheet" />
    <link href="~/css/customs/plugins/light/filepond/custom-filepond.css" rel="stylesheet" />

    <link href="~/css/customs/assets/light/apps/blog-create.css" rel="stylesheet" />
    <style>
        .featured-image{
            background-size: cover;
            height: 650px;
            border-radius:20px;
            overflow:hidden;
        }

        .class-info-wrapper {
            margin-top: 40px;
        }

        .class-section {
            margin-bottom: 35px;
        }

        .section-title {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 20px;
            border-left: 4px solid #4361ee;
            padding-left: 10px;
        }

        .class-info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
            gap: 20px;
        }

        .info-item {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
        }

        .info-label {
            display: block;
            font-size: 13px;
            color: #888;
        }

        .info-value {
            font-weight: 600;
            font-size: 15px;
        }

        .class-description {
            line-height: 1.8;
            font-size: 15px;
        }

            .class-description p {
                margin-bottom: 10px;
            }

        .class-extra {
            padding-left: 18px;
        }

            .class-extra li {
                margin-bottom: 8px;
                line-height: 1.6;
            }

        .empty-description {
            color: #999;
            font-style: italic;
        }


        /* Enrollment */
        .enroll-box {
            border: 1px solid #e0e6ed;
            border-radius: 10px;
            padding: 25px;
            background: #fff;
            margin-top: 25px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.05);
        }

        .enroll-header h4 {
            font-weight: 600;
            margin: 0;
        }

        .enroll-message {
            margin: 20px 0;
            color: #555;
        }

        .enroll-price {
            display: flex;
            justify-content: space-between;
            background: #f8f9fa;
            padding: 12px 15px;
            border-radius: 6px;
        }

        .price-label {
            font-weight: 500;
        }

        .price-value {
            font-size: 18px;
            font-weight: 600;
            color: #e7515a;
        }

        .enroll-action {
            margin-top: 20px;
            text-align: right;
        }

        .btn-enroll {
            padding: 10px 20px;
            font-weight: 600;
        }

        /* css for rating */
        .review-box {
            margin-top: 25px;
            padding: 20px;
            border: 1px solid #eee;
            border-radius: 8px;
            background: #fafafa;
        }

        .review-title {
            font-weight: 600;
            margin-bottom: 10px;
        }

        .review-guide {
            background: #f1f5ff;
            border-left: 4px solid #3b82f6;
            padding: 12px 15px;
            margin-bottom: 15px;
            border-radius: 4px;
        }

            .review-guide ul {
                margin: 5px 0 0 18px;
            }

        .rating-text {
            margin-top: 8px;
            font-weight: 500;
            color: #555;
            font-weight:bold;
        }

        .star-rating {
            font-size: 30px;
            color: #ddd;
            cursor: pointer;
        }

        .star {
            margin-right: 5px;
        }

            .star.active {
                color: #ffc107;
            }

        .review-comment {
            margin-top: 15px;
        }

        .review-action {
            margin-top: 15px;
        }

        #attendanceModal .modal-body {
            max-height: 60vh;
            overflow-y: auto;
        }

        #attendanceModal table {
            width: 100%;
        }

        #attendanceModal thead th {
            position: sticky;
            top: 0;
            background: white;
            z-index: 2;
        }



        .class-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 30px;
            margin-top: 30px;
        }

        /* LEFT */
        .class-main {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .section-card {
            background: #fff;
            border-radius: 16px;
            padding: 22px;
            border: 1px solid #eee;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 15px;
        }

        /* highlight list */
        .highlight-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 20px;
        }

        .highlight-item {
            font-size: 14px;
            color: #333;
        }

            .highlight-item::before {
                content: "✔";
                color: #28a745;
                margin-right: 8px;
            }

        /* description */
        .class-description {
            font-size: 14px;
            line-height: 1.6;
            color: #444;
        }

        /* RIGHT */
        .class-sidebar {
            position: sticky;
            top: 20px;
            height: fit-content;
        }

        .price-card {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #eee;
        }

        .price {
            font-size: 26px;
            font-weight: 700;
            color: #e53935;
            margin-bottom: 15px;
        }

        .info-list {
            margin-top: 10px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            padding: 8px 0;
            border-bottom: 1px dashed #eee;
        }

            .info-row span:first-child {
                color: #777;
            }

        .enroll-btn {
            width: 100%;
            margin-top: 15px;
            padding: 12px;
            font-weight: 600;
            border-radius: 10px;
        }



        .section-block {
            margin-top: 30px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

            .section-header h4 {
                font-size: 18px;
                font-weight: 700;
            }

        .card-table {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            border: 1px solid #eee;
        }

        /* table */
        .table-modern {
            width: 100%;
            border-collapse: collapse;
        }

            .table-modern thead {
                background: #f8f9fa;
            }

            .table-modern th {
                font-size: 13px;
                font-weight: 600;
                padding: 12px;
                color: #555;
            }

            .table-modern td {
                padding: 12px;
                font-size: 14px;
                border-top: 1px solid #f1f1f1;
            }

            .table-modern tbody tr:hover {
                background: #fafafa;
            }

        /* badge */
        .badge-modern {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-success {
            background: #e6f7ee;
            color: #1aa053;
        }

        .badge-warning {
            background: #fff4e5;
            color: #f59e0b;
        }

        .badge-danger {
            background: #fde8e8;
            color: #e53935;
        }

        .badge-gray {
            background: #eee;
            color: #555;
        }

        /* link */
        .link-action {
            color: #0d6efd;
            cursor: pointer;
            font-weight: 500;
        }

            .link-action:hover {
                text-decoration: underline;
            }

        /* modal */
        .modal-content {
            border-radius: 16px;
        }



        .enroll-card, .review-card {
            background: #fff;
            border-radius: 16px;
            padding: 22px;
            border: 1px solid #eee;
            margin-top: 20px;
        }

        .enroll-title {
            font-size: 18px;
            font-weight: 700;
        }

        .enroll-message {
            font-size: 14px;
            color: #555;
            margin: 12px 0;
        }

        .price-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 12px;
            margin-top: 10px;
        }

        .price-value {
            font-size: 24px;
            font-weight: 700;
            color: #e53935;
        }

        .badge-modern {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-success {
            background: #e6f7ee;
            color: #1aa053;
        }

        .badge-warning {
            background: #fff4e5;
            color: #f59e0b;
        }

        .badge-danger {
            background: #fde8e8;
            color: #e53935;
        }

        .btn-enroll {
            width: 100%;
            margin-top: 15px;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
        }

        /* rating */
        .star-rating {
            font-size: 26px;
            color: #ddd;
            cursor: pointer;
        }

            .star-rating .star.active {
                color: #ffc107;
            }

        .rating-text {
            margin-top: 8px;
            font-size: 14px;
            font-weight: 500;
        }

        textarea {
            border-radius: 10px !important;
        }




        .modal-content {
            border-radius: 16px;
            overflow: hidden;
        }

        .modal-header {
            border-bottom: 1px solid #eee;
        }

        .modal-title {
            font-size: 18px;
            font-weight: 700;
        }

        /* table */
        .table-attendance-detail {
            width: 100%;
        }

            .table-attendance-detail th {
                background: #f8f9fa;
                font-size: 13px;
                color: #666;
                padding: 10px;
            }

            .table-attendance-detail td {
                padding: 12px;
                border-top: 1px solid #f1f1f1;
                font-size: 14px;
            }

            .table-attendance-detail tr:hover {
                background: #fafafa;
            }

        /* badge */
        .badge-status {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-present {
            background: #e6f7ee;
            color: #1aa053;
        }

        .status-absent {
            background: #fde8e8;
            color: #e53935;
        }

        .status-late {
            background: #fff4e5;
            color: #f59e0b;
        }
    </style>
}

@{
    var userJson = Context.Session.GetString("UserLogin");
    var user = new User();

    if (!string.IsNullOrEmpty(userJson))
    {
        user = JsonConvert.DeserializeObject<User>(userJson);
    }


    string backgroundImage;

    if (Model.ClassImage != null)
    {
        var base64 = Convert.ToBase64String(Model.ClassImage);
        backgroundImage = $"data:image/jpeg;base64,{base64}";
    }
    else
    {
        backgroundImage = Url.Content("~/images/lightbox-5.jpeg");
    }

    var students = ViewBag.Students;
    var teacherReviews = ViewBag.TeacherReviews;

    // Đánh giá chung trong lớp học
    var reviews = ViewBag.TeacherReviews as List<TeacherReview>;

    double avgRating = 0;
    int totalReviews = 0;

    if (reviews != null && reviews.Any())
    {
        totalReviews = reviews.Count;
        avgRating = reviews.Average(r => r.Rating);
    }

    var enrollment = ViewBag.Enrollment;
    var studentObj = ViewBag.StudentObj;
    var teaReviewOfStudent = ViewBag.TeaReview;
}



<div class="layout-px-spacing">

    <div class="middle-content container-xxl p-0">

        <div class="row layout-top-spacing">

            <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 mb-4">


                <div class="single-post-content">

                    <div class="featured-image" style="background: url('@backgroundImage') no-repeat center; background-size: cover;">

                        <div class="featured-image-overlay"></div>

                        <div class="post-header">

                            <div class="post-title">
                                <h1 class="mb-0">@Model.Name</h1>
                            </div>

                            <div class="post-meta-info d-flex justify-content-between">

                                <div class="media">
                                    <img src="~/images/th4.png" alt="profile">
                                    <div class="media-body">
                                        <h5>@Model.TeacherName</h5>
                                        <div class="teacher-rating">
                                            <span style="font-weight:600; color:#ffcece">@avgRating.ToString("0.0")</span>

                                            <span style="color:#ffc107; font-size:18px;">
                                                @{
                                                    int fullStars = (int)Math.Floor(avgRating);
                                                    bool halfStar = avgRating - fullStars >= 0.5;

                                                    for (int i = 0; i < fullStars; i++)
                                                    {
                                                        <span>★</span>
                                                    }

                                                    if (halfStar)
                                                    {
                                                        <span>☆</span>
                                                    }

                                                    for (int i = fullStars + (halfStar ? 1 : 0); i < 5; i++)
                                                    {
                                                        <span style="color:#ddd;">★</span>
                                                    }
                                                }
                                            </span>

                                            <span style="color:#ffcece">(@totalReviews đánh giá)</span>
                                        </div>
                                        <p>Ngày dạy: @Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </div>

                                <div class="align-self-center">
                                    <button class="btn btn-success btn-icon btn-share btn-rounded">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-share-2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                                    </button>
                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="class-layout">

                        <!-- LEFT -->
                        <div class="class-main">

                            <!-- GIỚI THIỆU -->
                            <div class="section-card">
                                <div class="section-title">📘 Giới thiệu khóa học</div>

                                <div class="class-description">
                                    @if (!string.IsNullOrEmpty(Model.Description))
                                    {
                                        @Html.Raw(Model.Description)
                                    }
                                    else
                                    {
                                        <i>Chưa có mô tả cho khóa học này.</i>
                                    }
                                </div>
                            </div>

                            <!-- BẠN SẼ HỌC ĐƯỢC -->
                            <div class="section-card">
                                <div class="section-title">🎯 Bạn sẽ học được gì?</div>

                                <div class="highlight-list">
                                    <div class="highlight-item">Nắm vững kiến thức cơ bản</div>
                                    <div class="highlight-item">Áp dụng vào thực tế</div>
                                    <div class="highlight-item">Học cùng giảng viên chuyên môn</div>
                                    <div class="highlight-item">Có lộ trình rõ ràng</div>
                                </div>
                            </div>

                            <!-- THÔNG TIN THÊM -->
                            <div class="section-card">
                                <div class="section-title">📌 Thông tin lớp học</div>

                                <div class="highlight-list">
                                    <div class="highlight-item">Giảng viên: @Model.TeacherName</div>
                                    <div class="highlight-item">Khóa học: @Model.CourseName</div>
                                    <div class="highlight-item">Số lượng: @Model.MaxStudents học viên</div>
                                    <div class="highlight-item">
                                        Thời gian:
                                        @Model.StartDate.ToString("dd/MM")
                                        - @Model.EndDate.ToString("dd/MM")
                                    </div>
                                </div>
                            </div>

                        </div>


                        <!-- RIGHT -->
                        <div class="class-sidebar">

                            <div class="price-card">

                                <div class="price">
                                    @Model.CoursePrice.ToString("N0") VNĐ
                                </div>

                                @* <button class="btn btn-success enroll-btn">
                                    🚀 Đăng ký ngay
                                </button> *@

                                <div class="info-list">

                                    <div class="info-row">
                                        <span>Khai giảng</span>
                                        <span>@Model.StartDate.ToString("dd/MM/yyyy")</span>
                                    </div>

                                    <div class="info-row">
                                        <span>Kết thúc</span>
                                        <span>@Model.EndDate.ToString("dd/MM/yyyy")</span>
                                    </div>

                                    <div class="info-row">
                                        <span>Học viên tối đa</span>
                                        <span>@Model.MaxStudents</span>
                                    </div>

                                    <div class="info-row">
                                        <span>Giảng viên</span>
                                        <span>@Model.TeacherName</span>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    @if(user != null)
                    {
                        if(user.RoleId == (int)ERoleName.Teacher)
                        {
                            <div class="post-info">

                                <hr>

                                <!-- DATATABLE -->
                                <div class="row layout-top-spacing">
                                    <div class="col-xl-12 col-lg-12 col-sm-12">
                                        <div class="section-block">

                                            <div class="section-header">
                                                <h4>👨‍🎓 Học viên trong lớp</h4>
                                            </div>

                                            <div class="card-table">

                                                <table class="table-modern">

                                                    <thead>
                                                        <tr>
                                                            <th>#</th>
                                                            <th>Mã HV</th>
                                                            <th>Tên</th>
                                                            <th>Giới tính</th>
                                                            <th>Ngày đăng ký</th>
                                                            <th>Trạng thái</th>
                                                            <th></th>
                                                        </tr>
                                                    </thead>

                                                    <tbody>
                                                        @{
                                                            int sttStd = 1;
                                                        }

                                                        @foreach (var student in students)
                                                        {
                                                            <tr>
                                                                <td>@sttStd</td>
                                                                <td>@student.StudentId</td>
                                                                <td>@student.Fullname</td>
                                                                <td>@(((EGender)student.Gender).GetDisplayName())</td>
                                                                <td>@student.EnrollDate.ToString("dd/MM/yyyy")</td>

                                                                <td>
                                                                    <span class="badge-modern badge-success">
                                                                        @(((EEnrollStatus)student.EnrollStatus).GetDisplayName())
                                                                    </span>
                                                                </td>

                                                                <td>
                                                                    <span class="link-action view-attendance"
                                                                          data-id="@student.StudentId">
                                                                        Xem
                                                                    </span>
                                                                </td>
                                                            </tr>

                                                            sttStd++;
                                                        }

                                                    </tbody>

                                                </table>

                                            </div>

                                        </div>
                                    </div>
                                    <div class="modal fade" id="attendanceModal" tabindex="-1">
                                        <div class="modal-dialog modal-lg modal-dialog-centered">

                                            <div class="modal-content">

                                                <!-- HEADER -->
                                                <div class="modal-header">

                                                    <div>
                                                        <div class="modal-title">
                                                            📊 Chi tiết điểm danh
                                                        </div>

                                                        <div style="font-size:13px; color:#777;">
                                                            @if (studentObj != null)
                                                            {
                                                                <span>Học viên: <b>@studentObj.FullName</b></span>
                                                            }
                                                        </div>
                                                    </div>

                                                    <button type="button" class="btn-close" data-bs-dismiss="modal">X</button>

                                                </div>

                                                <!-- BODY -->
                                                <div class="modal-body">

                                                    <table class="table-attendance-detail">

                                                        <thead>
                                                            <tr>
                                                                <th>Thứ</th>
                                                                <th>Thời gian</th>
                                                                <th>Ngày học</th>
                                                                <th>Phòng</th>
                                                                <th>Trạng thái</th>
                                                            </tr>
                                                        </thead>

                                                        <tbody id="attendance-body">
                                                            <!-- JS render -->
                                                        </tbody>

                                                    </table>

                                                </div>

                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <!-- /DATATABLE -->

                                <hr>

                                <!-- DATATABLE -->
                                <div class="row layout-top-spacing">
                                    <div class="col-xl-12 col-lg-12 col-sm-12">
                                        <div class="section-block">

                                            <div class="section-header">
                                                <h4>⭐ Đánh giá học viên</h4>
                                            </div>

                                            <div class="card-table">

                                                <table id="teacher-table" class="table-modern">

                                                    <thead>
                                                        <tr>
                                                            <th>#</th>
                                                            <th>Mã</th>
                                                            <th>Đánh giá</th>
                                                            <th>Thời gian</th>
                                                            <th></th>
                                                        </tr>
                                                    </thead>

                                                    <tbody>
                                                        @{
                                                            int stt = 1;
                                                        }

                                                        @foreach (var review in teacherReviews)
                                                        {
                                                            string cls = "badge-gray";
                                                            string text = "";

                                                            switch (review.Rating)
                                                            {
                                                                case 1: cls = "badge-danger"; text = "Rất tệ"; break;
                                                                case 2: cls = "badge-warning"; text = "Tệ"; break;
                                                                case 3: cls = "badge-gray"; text = "Bình thường"; break;
                                                                case 4: cls = "badge-success"; text = "Tốt"; break;
                                                                case 5: cls = "badge-success"; text = "Rất tốt"; break;
                                                            }

                                                            <tr>
                                                                <td>@stt</td>
                                                                <td>@review.Id</td>

                                                                <td>
                                                                    <span class="badge-modern @cls">
                                                                        @text (@review.Rating ⭐)
                                                                    </span>
                                                                </td>

                                                                <td>@review.CreatedAt.ToString("dd/MM/yyyy")</td>

                                                                <td>
                                                                    <a href="javascript:void(0)"
                                                                          class="link-action view-comment"
                                                                          data-comment="@review.Comment">
                                                                        Xem
                                                                    </a>
                                                                </td>
                                                            </tr>

                                                            stt++;
                                                        }

                                                    </tbody>

                                                </table>

                                            </div>

                                        </div>
                                    </div>
                                </div>

                                <!-- /DATATABLE -->
                            </div>
                        }
                        else if (user.RoleId == (int)ERoleName.Student)
                        {
                            @if (enrollment == null)
                            {
                                <div class="enroll-card">

                                    <div class="enroll-title">🚀 Đăng ký lớp học</div>

                                    <div class="enroll-message">
                                        Bạn chưa tham gia lớp học với giảng viên <b>@Model.TeacherName</b>.
                                    </div>

                                    <div class="price-box">
                                        <div>Học phí</div>
                                        <div class="price-value">@Model.CoursePrice.ToString("N0") VNĐ</div>
                                    </div>

                                    <form method="post" action="@Url.Action("Create","Enrollment")" class="enroll-form">
                                        <input type="hidden" name="ClassId" value="@Model.Id" />
                                        <input type="hidden" name="StudentId" value="@studentObj.Id" />

                                        <button class="btn btn-success btn-enroll">
                                            Đăng ký ngay
                                        </button>
                                    </form>

                                </div>
                            }
                            else
                            {
                                string badgeClass = "";
                                string badgeText = "";
                                string message = "";
                                string btnText = "";
                                string action = "";
                                bool showBtn = false;

                                if (enrollment.Status == EEnrollStatus.InActive)
                                {
                                    badgeClass = "badge-warning";
                                    badgeText = "Chờ xác nhận";
                                    message = "Đơn đăng ký đang chờ duyệt.";
                                    btnText = "Hủy đăng ký";
                                    action = "Cancel";
                                    showBtn = true;
                                }
                                else if (enrollment.Status == EEnrollStatus.Active)
                                {
                                    badgeClass = "badge-success";
                                    badgeText = "Đã đăng ký";
                                    message = "Bạn đã đăng ký thành công lớp học.";
                                }
                                else
                                {
                                    badgeClass = "badge-danger";
                                    badgeText = "Đã hủy";
                                    message = "Bạn đã hủy lớp học.";
                                    btnText = "Đăng ký lại";
                                    action = "ReEnroll";
                                    showBtn = true;
                                }

                                <div class="enroll-card">

                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="enroll-title">📋 Trạng thái đăng ký</div>
                                        <span class="badge-modern @badgeClass">@badgeText</span>
                                    </div>

                                    <div class="enroll-message">@message</div>

                                    <div class="price-box">
                                        <div>Học phí</div>
                                        <div class="price-value">@Model.CoursePrice.ToString("N0") VNĐ</div>
                                    </div>

                                    @if (showBtn)
                                    {
                                        <a href="javascript:void(0)"
                                           data-url="@Url.Action(action, "Enrollment", new { id = enrollment.Id })"
                                           class="btn btn-primary btn-enroll confirm-action">
                                            @btnText
                                        </a>
                                    }

                                </div>
                            }

                            @if (enrollment?.Status == EEnrollStatus.Active && Model.StartDate < DateTime.Now)
                            {
                                <div class="review-card">

                                    <div class="enroll-title">⭐ Đánh giá lớp học</div>

                                    <form method="post"
                                          action="@Url.Action(teaReviewOfStudent == null ? "Insert" : "Update", "TeacherReview")">

                                        <input type="hidden" name="ClassId" value="@Model.Id" />
                                        <input type="hidden" name="StudentId" value="@studentObj.Id" />
                                        <input type="hidden" name="TeacherId" value="@Model.TeacherId" />
                                        <input type="hidden" id="ratingValue" name="Rating"
                                               value="@(teaReviewOfStudent?.Rating ?? 0)" />

                                        <!-- STAR -->
                                        <div class="star-rating">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <span class="star @(teaReviewOfStudent?.Rating >= i ? "active" : "")"
                                                      data-value="@i">★</span>
                                            }
                                        </div>

                                        <div id="ratingText" class="rating-text">
                                            Hãy chọn số sao
                                        </div>

                                        <div class="mt-3">
                                            <textarea name="Comment"
                                          class="form-control"
                                          placeholder="Chia sẻ cảm nhận của bạn...">@teaReviewOfStudent?.Comment</textarea>
                                        </div>

                                        <button class="btn btn-success btn-enroll mt-3">
                                            @(teaReviewOfStudent == null ? "Gửi đánh giá" : "Cập nhật")
                                        </button>

                                    </form>

                                </div>
                            }
                        }
                    }
                    

                </div>


            </div>

        </div>

    </div>

</div>

