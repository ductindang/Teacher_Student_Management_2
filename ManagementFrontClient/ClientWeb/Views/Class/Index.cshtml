@using BLL.Response
@{
    ViewData["Title"] = "Lớp học";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model IEnumerable<ClassDetailResponse>

<style>
    .fixed-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .card.style-2 {
        height: 100%;
    }

        .card.style-2 .card-body {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
</style>

<div class="middle-content container-xxl p-0">
    <div id="tabsSimple" class="col-xl-12 col-12 layout-spacing">
        <div class="statbox widget box box-shadow" style="margin-top: 30px">
            <div class="widget-content widget-content-area">

                <div class="simple-pill">

                    <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="pills-home-icon-tab" data-bs-toggle="pill" data-bs-target="#pills-home-icon" type="button" role="tab" aria-controls="pills-home-icon" aria-selected="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-home"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                                Đang diễn ra
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pills-profile-icon-tab" data-bs-toggle="pill" data-bs-target="#pills-profile-icon" type="button" role="tab" aria-controls="pills-profile-icon" aria-selected="false">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-user"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                Sắp tới
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pills-contact-icon-tab" data-bs-toggle="pill" data-bs-target="#pills-contact-icon" type="button" role="tab" aria-controls="pills-contact-icon" aria-selected="false">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                Đã kết thúc
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content" id="pills-tabContent">
                        <div class="tab-pane fade show active" id="pills-home-icon" role="tabpanel" aria-labelledby="pills-home-icon-tab" tabindex="0">
                            <p class="mt-3">Các lớp học mà bạn đang tham gia sẽ được hiển thị và cập nhật bên dưới, 
                                giúp bạn quản lý lớp học dễ hơn. Nếu có vấn đề gì thắc mắc xin liên hệ qua quản trị
                                viên: số điện thoại - 1900 0000</p>
                            <div class="row">

                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-4 col-sm-6 mb-4">
                                            <a asp-controller="Class" asp-action="Details" asp-route-id="@item.Id" class="card style-2 mb-md-0 mb-4">
                                                @if (item.ClassImage != null)
                                                {
                                                    var base64 = Convert.ToBase64String(item.ClassImage);
                                                    var imgSrc = $"data:image/jpeg;base64,{base64}";

                                                    <img src="@imgSrc"
                                                            class="card-img-top fixed-img"
                                                            alt="...">
                                                }
                                                else
                                                {
                                                    <img src="images/Student-Management-Logo.jpg"
                                                         class="card-img-top fixed-img"
                                                         alt="...">
                                                }

                                                <div class="card-body px-0 pb-0">
                                                    <h5 class="card-title mb-3">@item.Name</h5>
                                                    <div class="media mt-4 mb-0 pt-1">
                                                        <img src="images/Student-Management-Logo.jpg" class="card-media-image me-3" alt="">
                                                        <div class="media-body">
                                                            <h4 class="media-heading mb-1">@item.CourseName</h4>
                                                            <p class="media-text">@item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </a>
                                        </div>
                                    }
                                }

                            </div>
                        </div>
                        <div class="tab-pane fade" id="pills-profile-icon" role="tabpanel" aria-labelledby="pills-profile-icon-tab" tabindex="0">
                            <p class="mt-3">
                                Các lớp học sắp tới sẽ được hiển thị và cập nhật bên dưới, hãy nhanh chóng đăng ký để 
                                cùng tham gia với chúng tôi. Nếu có vấn đề gì thắc mắc xin liên hệ qua quản trị
                                viên: số điện thoại - 1900 0000
                            </p>
                            <div id="upcomingClassContainer"></div>
                        </div>
                        <div class="tab-pane fade" id="pills-contact-icon" role="tabpanel" aria-labelledby="pills-contact-icon-tab" tabindex="0">
                            <p>
                                Các lớp học bạn đã hoàn thành sẽ được hiển thị và cập nhật bên dưới, hãy xem lại về lớp học này. 
                                Nếu có vấn đề gì thắc mắc xin liên hệ qua quản trị viên: số điện thoại - 1900 0000
                            </p>
                            <div id="finishedClassContainer"></div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>

<script>

    document.getElementById("pills-profile-icon-tab")
        .addEventListener("click", function () {

            fetch('/Class/UpcommingClass')
                .then(response => response.text())
                .then(data => {
                    document.getElementById("upcomingClassContainer").innerHTML = data;
                });

        });

    document.getElementById("pills-contact-icon-tab")
        .addEventListener("click", function () {

            fetch('/Class/FinishedClass')
                .then(response => response.text())
                .then(data => {
                    document.getElementById("finishedClassContainer").innerHTML = data;
                });

        });

</script>

