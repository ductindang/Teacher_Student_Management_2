@using BLL.DTOs
@using BLL.Response
@using ClientWeb.Helper.Extensions
@using Newtonsoft.Json
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model List<ClassDetailResponse>

@section HeaderStyles {
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/blog-post.css" />
    <link rel="stylesheet" href="~/css/customs/assets/dark/apps/blog-post.css" />
    <link rel="stylesheet" href="~/css/customs/assets/dark/apps/ecommerce-create.css" />
    <link rel="stylesheet" href="~/css/customs/assets/light/apps/ecommerce-create.css" />

    <link rel="stylesheet" href="~/plugins/flatpickr/flatpickr.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/dark/flatpickr/custom-flatpickr.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/light/flatpickr/custom-flatpickr.css" />

    <link rel="stylesheet" href="~/css/customs/plugins/light/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/css/customs/plugins/dark/tomSelect/custom-tomSelect.css" />
    <link rel="stylesheet" href="~/plugins/tomSelect/tom-select.default.min.css" />

    <style>
        /* ===== GLOBAL ===== */
        .dashboard {
            max-width: 1400px;
            margin: auto;
            padding: 30px;
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #f6f8ff, #eef1ff);
            min-height: 100vh;
        }

        /* ===== GREETING ===== */
        .greetingDiv {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(14px);
            border-radius: 20px;
            padding: 25px 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .teacherGreeting {
            font-size: 26px;
            font-weight: 700;
            background: linear-gradient(90deg, #6651e4, #8f7bff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .makeFlexGreeting {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 6px;
            font-size: 14px;
            color: #666;
        }

        .motivation-quote {
            margin-top: 15px;
            font-style: italic;
            font-size: 15px;
            color: #444;
            display: flex;
            justify-content: space-between;
        }

        /* ===== ALERT CARD ===== */
        .lowAvailabilityAlertCard {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 30px;
            padding: 25px;
            border-radius: 20px;
            background: linear-gradient(135deg, #6651e4, #8f7bff);
            color: white;
            box-shadow: 0 15px 35px rgba(102,81,228,0.25);
        }

        .alertContent {
            display: flex;
            justify-content: space-between;
            width: 100%;
            flex-wrap: wrap;
        }

        .slotInfo h3 {
            margin-top: 5px;
            font-size: 18px;
            font-weight: 600;
        }

        .alertText {
            opacity: 0.9;
        }

        /* BUTTON */
        .primaryBtn {
            background: white;
            color: #6651e4;
            border: none;
            padding: 10px 18px;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.25s;
        }

            .primaryBtn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(0,0,0,0.15);
            }

        /* ===== CLASS LIST ===== */
        .classList {
            margin-top: 40px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
            gap: 20px;
        }

        /* CARD */
        .classCard {
            position: relative;
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            padding: 25px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            display: flex;
            justify-content: space-between;
            align-items: center;
            overflow: hidden;
        }

            /* gradient border effect */
            .classCard::before {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: 20px;
                padding: 1px;
                background: linear-gradient(120deg, #6651e4, transparent);
                -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
            }

            /* hover */
            .classCard:hover {
                transform: translateY(-6px) scale(1.01);
                box-shadow: 0 15px 40px rgba(102,81,228,0.15);
            }

        /* LEFT */
        .classLeft {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .classTitle {
            font-size: 20px;
            font-weight: 700;
            color: #2b2b2b;
        }

        .classCourse {
            font-size: 14px;
            font-weight: 600;
            color: #6651e4;
        }

        .classInfo {
            font-size: 13px;
            color: #666;
        }

        /* RIGHT */
        .classRight {
            text-align: right;
        }

        .classTime {
            background: linear-gradient(135deg, #f1efff, #e7e4ff);
            padding: 12px 16px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 600;
            color: #3f3d56;
            line-height: 1.6;
        }

        /* ===== EMPTY ===== */
        .emptyState {
            margin-top: 50px;
            padding: 50px;
            text-align: center;
            border-radius: 20px;
            background: rgba(255,255,255,0.7);
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        }

            .emptyState h3 {
                font-size: 22px;
                color: #6651e4;
            }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 768px) {
            .classList

            {
                grid-template-columns: 1fr;
            }

            .classCard {
                flex-direction: column;
                align-items: flex-start;
                gap: 15px;
            }

            .classRight {
                width: 100%;
                text-align: left;
            }

            .classTime {
                width: 100%;
            }

        }
    </style>
}

@{
    var userJson = Context.Session.GetString("UserLogin");
    var user = new User();

    if (!string.IsNullOrEmpty(userJson))
    {
        user = JsonConvert.DeserializeObject<User>(userJson);
    }

    var teacherJson = Context.Session.GetString("Teacher");
    Teacher teacher = null;
    if (!string.IsNullOrEmpty(teacherJson))
    {
        teacher = JsonConvert.DeserializeObject<Teacher>(teacherJson);
    }

    var studentJson = Context.Session.GetString("Student");
    Student student = null;
    if (!string.IsNullOrEmpty(studentJson))
    {
        student = JsonConvert.DeserializeObject<Student>(studentJson);
    }
}

<div class="dashboard">

    <!-- Greeting -->
    <div class="greetingDiv">
        <div class="teacherGreeting">
            Chào mừng trở lại,
            @if (teacher != null)
            {
                <span>Giảng viên @teacher.FullName ✨</span>
            }
            else if (student != null)
            {
                <span>Học viên @student.FullName ✨</span>
            }
            else
            {
                <span>@(user?.Username ?? "") ✨</span>
            }
        </div>

        <div class="makeFlexGreeting">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-clock" viewBox="0 0 16 16">
                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z" />
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0" />
            </svg>
            <div class="timeDetails">
                Múi giờ hệ thống: (GMT+7) - Việt Nam
            </div>
        </div>
        @if (teacher != null)
        {
            <div class="motivation-quote">
                <p class="quote-text">Một người thầy giỏi không ngừng học hỏi mỗi ngày.</p>
                <p class="quote-author">— Inspirational Thought</p>
            </div>
        }
        else
        {
            <div class="motivation-quote">
                <p class="quote-text">Học tập là hành trình dài, không phải đích đến.</p>
                <p class="quote-author">— Inspirational Thought</p>
            </div>
        }

    </div>

    <!-- Alert Card -->
    <div class="lowAvailabilityAlertCard">
        <div class="iconContainer">
            <img class="lowAvailabilityAlertCard_issueIcon__w0dDy" style="width: 60px" src="https://ik.imagekit.io/brightchamps/dashboard//slots.gif" alt="icon">
        </div>

        <div class="alertContent">
            <div class="slotInfo">
                Hoạt động hôm nay
                <h3>Theo dõi và kiểm soát lịch dạy/học của bạn</h3>
            </div>

            <div class="alertAction">
                <div class="alertText">
                    Xem toàn bộ lịch trong tuần
                </div>
                <div style="margin-top: 20px">
                    <a class="primaryBtn" asp-controller="Schedule" asp-action="Index">Xem lịch chi tiết</a>
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="classList">
            @foreach (var item in Model)
            {
                <a asp-controller="Attendance" asp-action="Index" asp-route-scheduleId="@item.ScheduleId" asp-route-classId="@item.Id" class="dropdown-toggle">
                    <div class="classCard">

                        <div class="classLeft">
                            <div class="classTitle">@item.Name</div>
                            <div class="classCourse">@item.CourseName</div>

                            <div class="classInfo">
                                📆 Thời gian: @item.StartDate.ToString("dd/MM/yyyy") - @item.EndDate.ToString("dd/MM/yyyy")
                            </div>

                            <div class="classInfo">
                                👨‍🎓 Sĩ số tối đa: @item.MaxStudents
                            </div>
                        </div>

                        @if(item.StartTime != null && item.EndTime != null)
                        {
                            <div class="classRight">
                                <div class="classTime">
                                    🗓 @item.DayOfWeek.GetDisplayName() <br />
                                    ⏰ @item.StartTime?.ToString(@"hh\:mm")
                                    -
                                    @item.EndTime?.ToString(@"hh\:mm") <br />
                                    📍 @item.Room
                                </div>
                            </div>
                        }

                    </div>
                </a>
                
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="emptyState">
            <h3>Không có lớp học</h3>
            <p>Bạn không có bất kỳ lớp học nào ngày hôm nay.</p>
        </div>
    }
    

</div>

@section Scripts {

    <script src="/plugins/tomSelect/tom-select.base.js"></script>
    <script src="/plugins/flatpickr/flatpickr.js"></script>
    @* <script src="/plugins/tomSelect/custom-tom-select.js"></script> *@

