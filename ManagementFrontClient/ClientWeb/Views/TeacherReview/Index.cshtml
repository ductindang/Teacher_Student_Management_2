@using BLL.Response
@{
    ViewData["Title"] = "Đánh giá giảng viên";
    Layout = "~/Views/Shared/_LayoutProject.cshtml";
}

@model IEnumerable<TeacherClassReviewResponse>

@{
    var reviewed = Model?.Where(x => x.TeacherReviewId > 0).ToList();
    var notReviewed = Model?.Where(x => x.TeacherReviewId <= 0).ToList();
}

<style>
    .fixed-img {
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .card.style-2 {
        height: 100%;
    }

        .card.style-2 .card-body {
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

    .empty-box {
        width: 100%;
        padding: 40px 20px;
        border: 2px dashed #d3d3d3;
        border-radius: 10px;
        text-align: center;
        color: #6c757d;
        font-size: 16px;
        background: #fafafa;
        margin-top: 20px;
    }

        .empty-box span {
            display: block;
            font-size: 14px;
            margin-top: 5px;
        }

    .review-info{
        color: black;
        text-align: center;
        font-size: 18px;
    }



    .card.style-2 {
        display: flex !important;
        flex-direction: row !important; /* ép nằm ngang */
        align-items: center !important;
        justify-content: space-between;
        border-radius: 16px;
        background: #fff;
        border: 1px solid #eee;
        padding: 16px 20px;
        transition: 0.25s;
    }

        .card.style-2:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

    .fixed-img {
        width: 80px;
        height: 80px;
        object-fit: contain;
        margin-right: 15px;
        flex-shrink: 0;
    }

    .card-body {
        flex: 1;
        padding: 0 !important;
        text-align: left !important; /* fix bị center */
    }

    .card-title {
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .media {
        display: flex;
        align-items: center;
    }

        .media img {
            width: 24px;
            height: 24px;
            margin-right: 6px;
        }

    .media-heading {
        font-size: 13px;
        font-weight: 500;
    }

    .media-text {
        font-size: 12px;
        color: #777;
    }

    .status-badge {
        display: inline-block;
        background: #007bff;
        color: #fff;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 4px;
    }

    .date-box {
        text-align: right;
        font-size: 13px;
        color: #555;
        min-width: 70px;
        flex-shrink: 0;
    }

    .arrow {
        font-size: 11px;
        color: #aaa;
    }
</style>

<div class="middle-content container-xxl p-0">
    <div id="tabsSimple" class="col-xl-12 col-12 layout-spacing">
        <div class="statbox widget box box-shadow" style="margin-top: 30px">
            <div class="widget-content widget-content-area">

                <div class="simple-pill">

                    <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="pills-home-icon-tab" data-bs-toggle="pill" data-bs-target="#pills-home-icon" type="button" role="tab" aria-controls="pills-home-icon" aria-selected="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-home"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                                Các lớp học của bạn
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content" id="pills-tabContent">
                        <div class="tab-pane fade show active" id="pills-home-icon" role="tabpanel" aria-labelledby="pills-home-icon-tab" tabindex="0">
                            <p class="mt-3">
                                Những đánh giá của bạn sẽ giúp chúng tôi ngày càng hoàn thiện hơn.
                                Nếu có thể, bạn hãy dành ít phút chia sẻ cảm nhận về lớp học và giáo viên nhé.
                                Mỗi góp ý của bạn đều rất quý giá đối với chúng tôi. Cảm ơn bạn rất nhiều
                                và chúc bạn luôn có những giờ học thật vui và bổ ích!
                            </p>
                            <div class="row">

                                @if (Model != null && Model.Any())
                                {
                                    <hr />
                                    <div class="mt-3 fw-bold review-info">Lớp học đã đánh giá</div>
                                    if(reviewed != null && reviewed.Any())
                                    {
                                        @foreach (var item in reviewed)
                                        {
                                            <div class="col-12 mb-3">
                                                <a asp-controller="Class" asp-action="Details" asp-route-id="@item.Id" class="card style-2">
                                                    @if (item.ClassImage != null)
                                                    {
                                                        var base64 = Convert.ToBase64String(item.ClassImage);
                                                        var imgSrc = $"data:image/jpeg;base64,{base64}";

                                                            <img src="@imgSrc"
                                                                class="card-img-top fixed-img"
                                                                alt="..." />
                                                    }
                                                    else
                                                    {
                                                        <img src="images/education-logo-template-free.jpg" class="card-img-top fixed-img" alt="...">
                                                    }

                                                    <!-- CONTENT -->
                                                    <div class="card-body">

                                                        <div class="status-badge">Class</div>

                                                        <h5 class="card-title">
                                                            @item.ClassName
                                                        </h5>

                                                        <div class="media">
                                                            <img src="images/education-logo-template-free.jpg">

                                                            <div>
                                                                <div class="media-heading">
                                                                    @item.CourseName
                                                                </div>

                                                                <div class="media-text">
                                                                    📅 @item.StartDate.ToString("dd/MM/yyyy")
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>

                                                    <!-- DATE RIGHT -->
                                                    <div class="date-box">
                                                        <div>@item.StartDate.ToString("dd/MM")</div>
                                                        <div class="arrow">→</div>
                                                        <div>@item.EndDate.ToString("dd/MM")</div>
                                                    </div>
                                                </a>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="col-12">
                                            <div class="empty-box">
                                                Bạn chưa đánh giá lớp học nào
                                                <span>Hãy giúp chúng tôi đưa ra các đánh giá để chúng tôi cải thiện hơn</span>
                                            </div>
                                        </div>
                                    }

                                    <hr />

                                    <div class="mt-4 fw-bold review-info">Lớp học bạn chưa đánh giá</div>
                                    if(notReviewed != null && notReviewed.Any())
                                    {
                                        @foreach (var item in notReviewed)
                                        {
                                            <div class="col-12 mb-3">
                                                <a asp-controller="Class" asp-action="Details" asp-route-id="@item.Id" class="card style-2">
                                                    @if (item.ClassImage != null)
                                                    {
                                                        var base64 = Convert.ToBase64String(item.ClassImage);
                                                        var imgSrc = $"data:image/jpeg;base64,{base64}";

                                                        <div class="mb-3">
                                                            <img src="@imgSrc"
                                                                 class="card-img-top fixed-img"
                                                                 alt="..." />
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <img src="images/education-logo-template-free.jpg" class="card-img-top fixed-img" alt="...">
                                                    }

                                                    <!-- CONTENT -->
                                                    <div class="card-body">

                                                        <div class="status-badge">Class</div>

                                                        <h5 class="card-title">
                                                            @item.ClassName
                                                        </h5>

                                                        <div class="media">
                                                            <img src="images/education-logo-template-free.jpg">

                                                            <div>
                                                                <div class="media-heading">
                                                                    @item.CourseName
                                                                </div>

                                                                <div class="media-text">
                                                                    📅 @item.StartDate.ToString("dd/MM/yyyy")
                                                                </div>
                                                            </div>
                                                        </div>

                                                    </div>

                                                    <!-- DATE RIGHT -->
                                                    <div class="date-box">
                                                        <div>@item.StartDate.ToString("dd/MM")</div>
                                                        <div class="arrow">→</div>
                                                        <div>@item.EndDate.ToString("dd/MM")</div>
                                                    </div>
                                                </a>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="col-12">
                                            <div class="empty-box">
                                                Không có lớp học nào bạn chưa đánh giá
                                                <span>Tất cả lớp học của bạn đã được đánh giá</span>
                                            </div>
                                        </div>
                                    }

                                }

                            </div>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>

