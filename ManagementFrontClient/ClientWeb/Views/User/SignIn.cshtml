@model BLL.DTOs.User

@{
    ViewData["Title"] = "SignIn";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdminWeb.styles.css" asp-append-version="true" />
    <link href="~/plugins/notification/snackbar/snackbar.min.css" rel="stylesheet" />
    <script src="/js/customs/layouts/modern-light-menu/loader.js"></script>
    <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700" rel="stylesheet">

    <style>
        .notification {
            position: fixed;
            top: 60px;
            right: 20px;
            font-size: 30px;
            background-color: #5cb85c;
            color: white;
            padding: 10px;
            border-radius: 4px;
            display: none;
            z-index: 1000;
        }

        .login-page {
            margin: 0;
            height: 100vh;
            font-family: 'Nunito', sans-serif;
            background: linear-gradient(135deg,#4f46e5,#9333ea);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .login-card {
            background: white;
            border-radius: 14px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .login-header h2 {
                font-weight: 700;
            }

            .login-header p {
                color: #777;
            }

        .input-group-custom {
            margin-bottom: 20px;
        }

            .input-group-custom label {
                font-weight: 600;
                margin-bottom: 6px;
                display: block;
            }

            .input-group-custom input {
                width: 100%;
                height: 45px;
                border-radius: 8px;
                border: 1px solid #ddd;
                padding: 10px;
                transition: 0.3s;
            }

                .input-group-custom input:focus {
                    border-color: #6366f1;
                    box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
                }

        .password-box {
            position: relative;
        }

        #togglePassword {
            position: absolute;
            right: 12px;
            top: 36px;
            cursor: pointer;
        }

        .login-options {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .btn-login {
            width: 100%;
            height: 45px;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-login:hover {
                opacity: 0.9;
            }
    </style>
</head>

<body class="login-page">
    <div id="successNotification" class="notification"></div>

    <!-- LOADER (giữ nguyên) -->
    <div id="load_screen">
        <div class="loader">
            <div class="loader-content">
                <div class="spinner-grow align-self-center"></div>
            </div>
        </div>
    </div>

    <div class="login-wrapper">
        <div class="login-card">

            <div class="login-header">
                <h2>Đăng nhập giáo viên / học viên</h2>
                <p>Nhập email và mật khẩu để đăng nhập</p>
            </div>

            <form asp-action="SignIn" id="signin-form">

                <!-- EMAIL -->
                <div class="input-group-custom">
                    <label>Email</label>
                    <input id="email"
                           asp-for="Email"
                           class="form-control"
                           placeholder="Nhập email của bạn"
                           required>
                </div>

                <!-- PASSWORD -->
                <div class="input-group-custom password-box">
                    <label>Mật khẩu</label>

                    <input id="password"
                           type="password"
                           asp-for="PasswordHash"
                           class="form-control"
                           placeholder="Nhập mật khẩu"
                           required>

                    <span id="togglePassword">👁</span>
                </div>

                <!-- OPTIONS -->
                <div class="login-options">
                    <label>
                        <input type="checkbox" id="form-check-default">
                        Ghi nhớ đăng nhập
                    </label>

                    <a href="#">Quên mật khẩu?</a>
                </div>

                <!-- BUTTON -->
                <button type="submit" class="btn-login">
                    Đăng nhập
                </button>

            </form>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/user/signIn.js"></script>
    <script src="/js/customs/bootstrap/bootstrap.bundle.min.js"></script>

    <!-- toggle password (giữ nguyên logic) -->
    <script>
        const togglePassword = document.querySelector("#togglePassword");
        const password = document.querySelector("#password");

        togglePassword.addEventListener("click", function () {
            const type = password.getAttribute("type") === "password"
                ? "text"
                : "password";

            password.setAttribute("type", type);
            this.textContent = type === "password" ? "👁" : "🙈";
        });
    </script>

</body>
</html>