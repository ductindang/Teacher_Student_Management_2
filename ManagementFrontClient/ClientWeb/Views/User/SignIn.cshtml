@model BLL.DTOs.User

@{
    ViewData["Title"] = "SignIn";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AdminWeb.styles.css" asp-append-version="true" />
    <link href="~/plugins/notification/snackbar/snackbar.min.css" rel="stylesheet" />
    <script src="/js/customs/layouts/modern-light-menu/loader.js"></script>
    <link href="https://fonts.googleapis.com/css?family=Nunito:400,600,700" rel="stylesheet">
    <link href="/css/customs/layouts/modern-light-menu/light/loader.css" rel="stylesheet" />
    <link href="/css/customs/assets/light/scrollspyNav.css" rel="stylesheet" />

    <link href="/css/customs/layouts/modern-light-menu/light/structure.css" rel="stylesheet" type="text/css" />
    <link href="/css/customs/assets/light/components/modal.css" rel="stylesheet" type="text/css" />

    <link href="/plugins/highlight/styles/monokai-sublime.css" rel="stylesheet" />
    <link href="/plugins/waves/waves.min.css" rel="stylesheet" type="text/css" />

    <link href="/css/customs/plugins/light/perfect-scrollbar/perfect-scrollbar.css" rel="stylesheet" type="text/css" />

    <link href="~/css/customs/assets/light/main.css" rel="stylesheet" type="text/css" />

    <link href="/css/customs/layouts/modern-light-menu/light/plugin.css" rel="stylesheet" type="text/css" />

    <link href="/css/customs/assets/light/dashboard/dash_1.css" rel="stylesheet" type="text/css" />
    <link href="/css/customs/plugins/light/sweetalerts2/custom-sweetalert.css" rel="stylesheet" type="text/css" />

    <link href="/css/customs/assets/light/authentication/auth-cover.css" rel="stylesheet" />

    <!-- END PAGE LEVEL PLUGINS/CUSTOM STYLES -->
    <style>
        .notification {
            position: fixed;
            top: 60px;
            right: 20px;
            font-size: 30px;
            background-color: #5cb85c;
            color: white;
            padding: 10px;
            border-radius: 4px;
            display: none;
            z-index: 1000;
        }

        .page-loading {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

    </style>


</head>
<body class="form">
    <div id="successNotification" class="notification"></div>

    <!-- BEGIN LOADER -->
    <div id="load_screen">
        <div class="loader">
            <div class="loader-content">
                <div class="spinner-grow align-self-center"></div>
            </div>
        </div>
    </div>
    <!-- END LOADER -->


    <div class="auth-container d-flex">

        <div class="container mx-auto align-self-center">

            <div class="row">

                <!-- LEFT SIDE -->
                <div class="col-6 d-lg-flex d-none h-100 my-auto top-0 start-0 text-center justify-content-center flex-column">
                    <div class="auth-cover-bg-image"></div>
                    <div class="auth-overlay"></div>

                    <div class="auth-cover">

                        <div class="position-relative">

                            <img src="/images/auth-cover.svg" alt="auth-img">

                            <h2 class="mt-5 text-white font-weight-bolder px-2">
                                Chào mừng bạn đến với trang web quản lý học viên và giáo viên
                            </h2>

                            <p class="text-white px-2">
                                Hệ thống dễ thiết lập với trải nghiệm người dùng tuyệt vời. Hãy bắt đầu sử dụng ứng dụng ngay hôm nay.
                            </p>

                        </div>

                    </div>

                </div>

                <!-- LOGIN FORM -->
                <div class="col-xxl-4 col-xl-5 col-lg-5 col-md-8 col-12 d-flex flex-column align-self-center ms-lg-auto me-lg-0 mx-auto">
                    <div class="card">
                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-12 mb-3">
                                    <h2>Đăng nhập giáo viên / học viên</h2>
                                    <p>Nhập email và mật khẩu để đăng nhập</p>
                                </div>

                                <form asp-action="SignIn" id="signin-form">

                                    <!-- EMAIL -->
                                    <div class="col-md-12">
                                        <div class="mb-3">
                                            <label class="form-label" for="email">Email</label>
                                            <input id="email"
                                                   asp-for="Email"
                                                   class="form-control"
                                                   placeholder="Nhập email của bạn"
                                                   required>
                                        </div>
                                    </div>

                                    <!-- PASSWORD -->
                                    <div class="col-12">
                                        <div class="mb-4 position-relative">
                                            <label class="form-label" for="password">Mật khẩu</label>

                                            <input id="password" type="password" asp-for="PasswordHash"
                                                   class="form-control pe-5"
                                                   placeholder="Nhập mật khẩu" required>

                                            <span id="togglePassword"
                                                  style="position:absolute; right:15px; top:38px; cursor:pointer; font-size: 25px">
                                                👁
                                            </span>
                                        </div>
                                    </div>

                                    <!-- REMEMBER -->
                                    <div class="col-12">
                                        <div class="mb-3">
                                            <div class="form-check form-check-primary form-check-inline">
                                                <input class="form-check-input me-3"
                                                       type="checkbox"
                                                       id="form-check-default">

                                                <label class="form-check-label" for="form-check-default">
                                                    Ghi nhớ đăng nhập
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- BUTTON -->
                                    <div class="col-12">
                                        <div class="mb-4">
                                            <button type="submit" class="btn btn-secondary w-100">
                                                ĐĂNG NHẬP
                                            </button>
                                        </div>
                                    </div>

                                </form>

                            </div>

                        </div>
                    </div>
                </div>

            </div>

        </div>

    </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/user/signIn.js"></script>
    <script src="/js/customs/bootstrap/bootstrap.bundle.min.js"></script>
    <script>
        const togglePassword = document.querySelector("#togglePassword");
        const password = document.querySelector("#password");

        togglePassword.addEventListener("click", function () {

            const type = password.getAttribute("type") === "password"
                ? "text"
                : "password";

            password.setAttribute("type", type);

            this.textContent = type === "password" ? "👁" : "🙈";
        });
    </script>

</body>
</html>